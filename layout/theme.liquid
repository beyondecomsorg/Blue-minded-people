<!doctype html>
<html
  {% if request.design_mode %}
    class="shopify-design-mode"
  {% endif %}
  lang="{{ request.locale.iso_code }}"
>
  <head>
    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}

    {% # theme-check-disable RemoteAsset %}
    {% comment %} This a way to wait for main content to load when navigating to a new page so that the view transitions can work consistently {% endcomment %}
    {% if settings.transition_to_main_product or settings.page_transition_enabled %}
      <link
        rel="expect"
        href="#MainContent"
        blocking="render"
        id="view-transition-render-blocker"
      >
    {% endif %}

    {% style %}

@media only screen and (min-width: 768px){
.header__column--left,
.header__column--right,
.header__column--center{
  width: 33% !important;
}
.header__columns.spacing-style {
  width: 100%;
}
}

@media only screen and (max-width: 767px){
  .section--full-width.section--full-width-margin>*{
    padding: 0 !important;
  }
  .menu-drawer.color-scheme-1{
   background: #0b1f33;
  }
  .menu-drawer__menu-item-text{
    font-size: 18px;
  }
  body #HeaderDrawer-catalog span.menu-drawer__menu-item-text.wrap-text{
    color: black;
  }
   header-component button, #header-component button{
    padding: 0 !important;
   }
   .header__columns.spacing-style {
      width: 100%;
      justify-content: space-between;
    }
    header-component .header-actions__action{
      padding: 0 !important;
    }
}

/* ============================================================================
   BRAND TYPOGRAPHY SYSTEM - BLUE MINDED PEOPLE
   ============================================================================ */

/* 1. Load Canela Custom Font */
@font-face {
  font-family: 'Canela';
  src: url('{{ "Canela-Light.woff2" | asset_url }}') format('woff2'),
       url('{{ "Canela-Light.woff" | asset_url }}') format('woff');
  font-weight: 300;
  font-style: normal;
  font-display: swap;
}
@font-face {
  font-family: 'Canela';
  src: url('{{ "Canela-Regular.woff2" | asset_url }}') format('woff2'),
       url('{{ "Canela-Regular.woff" | asset_url }}') format('woff');
  font-weight: 400;
  font-style: normal;
  font-display: swap;
}
@font-face {
  font-family: 'Canela';
  src: url('{{ "Canela-Medium.woff2" | asset_url }}') format('woff2'),
       url('{{ "Canela-Medium.woff" | asset_url }}') format('woff');
  font-weight: 500;
  font-style: normal;
  font-display: swap;
}

/* 2. Global Custom Properties */
:root {
  --font-heading: 'Canela', 'Freight Display', Georgia, serif;
  --font-body: 'Inter', system-ui, sans-serif;

  /* Propagate to Shopify theme tokens */
  --font-heading--family: var(--font-heading) !important;
  --font-body--family: var(--font-body) !important;
  --font-paragraph--family: var(--font-body) !important;
  --font-h1--family: var(--font-heading) !important;
  --font-h2--family: var(--font-heading) !important;
  --font-h3--family: var(--font-heading) !important;
  --font-h4--family: var(--font-heading) !important;
  --font-h5--family: var(--font-heading) !important;
  --font-h6--family: var(--font-heading) !important;
}

/* 3. Global CSS Applications */
h1, h2, h3, .h1, .h2, .h3, .editorial-headline, .hero-title, .section-title, .display-text {
  font-family: var(--font-heading) !important;
  letter-spacing: 0.02em !important;
  font-weight: 300 !important;
}

body, p, a, span, li, button, input, label, select, textarea, .nav-link, .product-title, .price {
  font-family: var(--font-body);
}

/* 4. Section-by-Section Specific Typography Overrides */

/* HEADER SECTION */
.header__logo-text, .header__logo a, .logo-text, .header-wordmark {
  font-family: var(--font-heading) !important;
  letter-spacing: 0.12em !important;
  text-transform: uppercase !important;
  font-weight: 300 !important;
}
.menu-list__link, .nav-link, .header-actions__action, .header-actions__action-label {
  font-family: var(--font-body) !important;
}

/* HERO SECTIONS (all four hero sections) */
.hero-section h1, .hero-section h2, .hero-section .h1, .hero-section .h2,
.hero h1, .hero h2, .hero .h1, .hero .h2 {
  font-family: var(--font-heading) !important;
  font-weight: 300 !important;
  letter-spacing: 0.02em !important;
}
.hero-section p, .hero-section .paragraph, .hero-section .rte,
.hero p, .hero .paragraph, .hero .rte {
  font-family: var(--font-body) !important;
}
.hero-section .button, .hero-section a.button, .hero .button, .hero a.button {
  font-family: var(--font-body) !important;
}





 body .wnt-eyebrow,
 body .wnt-product-brand,
  body .sfc-card-title,
  body .bpc-card-label,
  body .ebs-card-label {
  font-size: 16px !important;
  font-weight: 700 !important;
  }  
  body sfc-subheading{
  font-size: 16px !important;
  }

  body .sbc-heading,
  body .sfc-heading,
  body .timeline-tabs__heading,
  body .timeline-tabs__title,
  body .ebs-heading,
  body .wau-heading,
  body .war-static,
  body .war-word{
    font-size: 40px !important;
  }


@media only screen and (max-width: 768px){
    body .sbc-heading,
  body .sfc-heading,
  body .timeline-tabs__heading,
  body .timeline-tabs__title,
  body .ebs-heading,
  body .wau-heading,
  body .war-static,
  body .war-word{
    font-size: 28px !important;
  }

}

  

.trust-strip__heading{
  font-family: var(--font-heading) !important;
}



    body .wau-heading{
   font-weight: 300 !important;
    }
 body .sbc-card-btn,
 body .wau-cta{
   font-size: 12px !important;
 }
  
 body .wnt-subtext,
 body .sfc-card-subtitle,
 body .timeline-tabs__tab,
  .timeline-tabs__tab,
  body .timeline-tabs__text.rte p,
  body .wau-left .wau-body{
    font-size: 14px !important;
  }






/* WHAT'S NEW TODAY SECTION */
.wnt-eyebrow, .wnt-count {
  font-family: var(--font-heading) !important;
  font-weight: 300 !important;
}
.wnt-subtext, .wnt-cta, .wnt-product-brand, .wnt-arrow {
  font-family: var(--font-body) !important;
}

/* SHOP BY CATEGORY SECTION */
.sbc-heading {
  font-family: var(--font-heading) !important;
  font-weight: 300 !important;
}
.sbc-card-title, .sbc-card-btn {
  font-family: var(--font-body) !important;
}

/* FABRIC CATEGORY CAROUSEL */
.sfc-heading {
  font-family: var(--font-heading) !important;
  font-weight: 300 !important;
}
.sfc-subheading, .sfc-card-title, .sfc-card-subtitle, .sfc-arrow-btn, .sfc-pagination {
  font-family: var(--font-body) !important;
}

/* BRAND PRODUCT CAROUSEL */
.bpc-heading {
  font-family: var(--font-heading) !important;
  font-weight: 300 !important;
}
.bpc-card-label, .bpc-arrow {
  font-family: var(--font-body) !important;
}

/* OUR FAVOURITES HERO SECTION */
.orf-title {
  font-family: var(--font-heading) !important;
  font-weight: 300 !important;
}
.orf-eyebrow, .orf-subtitle, .orf-card-label {
  font-family: var(--font-body) !important;
}

/* TIMELINE TABS SECTION */
.timeline-tabs__heading, .timeline-tabs__title, .timeline-tabs__tab {
  font-family: var(--font-heading) !important;
  font-weight: 300 !important;
}
.timeline-tabs__text, .timeline-tabs__text p {
  font-family: var(--font-body) !important;
}

/* EXPLORE SELECTIONS GRID */
.ebs-heading, .ebs-card-label {
  font-family: var(--font-heading) !important;
  font-weight: 300 !important;
}

/* THREE-PANEL EDITORIAL SECTION */
.tpb-line2 {
  font-family: var(--font-heading) !important;
  font-weight: 300 !important;
}
.tpb-line1 {
  font-family: var(--font-body) !important;
}

/* ABOUT US / FAN CARDS SECTION */
.wau-heading {
  font-family: var(--font-heading) !important;
  font-weight: 300 !important;
}
.wau-stat-pill strong {
  font-family: var(--font-heading) !important;
  font-weight: 300 !important;
  color: var(--color-copper-rivet, #B87333) !important;
}
.wau-body, .wau-stat-pill span, .wau-cta, .wau-pcard__caption {
  font-family: var(--font-body) !important;
}

/* WE ARE ROTATING BANNER */
.war-static, .war-word {
  font-family: var(--font-heading) !important;
  font-weight: 300 !important;
}
.war-sub {
  font-family: var(--font-body) !important;
}

/* CUSTOM EDITORIAL SPLIT SECTION */
.ess-cta {
  font-family: var(--font-heading) !important;
  font-weight: 300 !important;
}
.ess-stats, .ess-body, .ess-caption, .ess-explore {
  font-family: var(--font-body) !important;
}

/* TRUST SCROLL STRIP */
.trust-strip, .trust-strip *, .trust-strip__heading, .trust-strip__subheading, .trust-strip__title, .trust-strip__text {
 /* font-family: var(--font-body) !important; */
}

/* CUSTOM FOOTER / FOOTER */
.custom-footer, .custom-footer *, .custom-footer h1, .custom-footer h2, .custom-footer h3, .custom-footer h4, .custom-footer h5, .custom-footer h6,
footer, footer *, .footer, .footer-heading {
  font-family: var(--font-body) !important;
}
.custom-footer h1, .custom-footer h2, .custom-footer h3, .custom-footer h4, .custom-footer h5, .custom-footer h6,
.footer-heading {
  font-weight: 500 !important;
}

    {% endstyle %}

    {%- render 'meta-tags' -%}
    {%- render 'stylesheets' -%}
    {%- render 'fonts' -%}
    {%- render 'scripts' -%}
    {%- render 'theme-styles-variables' -%}
    {%- render 'color-schemes' -%}

    {% if request.design_mode %}
      {%- render 'theme-editor' -%}
    {% endif %}

    {{ content_for_header }}

    <link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/@splidejs/splide@4.1.4/dist/css/splide.min.css"
/>

<script src="https://cdn.jsdelivr.net/npm/@splidejs/splide@4.1.4/dist/js/splide.min.js" defer></script>
    {% # theme-check-enable RemoteAsset %}
  </head>

  <body class="page-width-{{ settings.page_width }} card-hover-effect-{{ settings.card_hover_effect }}">
    {% render 'skip-to-content-link', href: '#MainContent', text: 'accessibility.skip_to_text' %}
    <div id="header-group">
      {% sections 'header-group' %}
    </div>

    <script>
      // Inline header height and menu style calculations to prevent layout shift
      // Note: Updates in calculateHeaderGroupHeight(), updateTransparentHeaderOffset() and setHeaderMenuStyle() utilities.js should be kept in sync with this function
      (function setHeaderHeighCustomProperties() {
        /*
         * Header calculation functions for maintaining CSS variables
         * Mimic calculateHeaderGroupHeight() in utilities.js
         */
        const header = document.querySelector('header-component');
        const headerGroup = document.querySelector('#header-group');
        const hasHeaderSection = headerGroup?.querySelector('.header-section');

        if (!header || !headerGroup) return;

        const headerTopRow = header.querySelector('.header__row--top');
        const headerHeight = header.offsetHeight;

        // Calculate the total height of the header group
        let headerGroupHeight = 0;
        const children = headerGroup.children;
        for (let i = 0; i < children.length; i++) {
          const element = children[i];
          if (element === header || !(element instanceof HTMLElement)) continue;
          headerGroupHeight += element.offsetHeight;
        }

        // Check for transparent header special case
        if (header.hasAttribute('transparent') && header.parentElement?.nextElementSibling) {
          headerGroupHeight += headerHeight;
        }

        // Set CSS variables
        document.body.style.setProperty('--header-height', `${headerHeight}px`);
        document.body.style.setProperty('--header-group-height', `${headerGroupHeight}px`);

        if (headerTopRow) {
          window.requestAnimationFrame(function () {
            document.body.style.setProperty('--top-row-height', `${headerTopRow.offsetHeight}px`);
          });
        }

        /**
         * Updates CSS custom properties for transparent header offset calculation
         * Mimic updateTransparentHeaderOffset() in utilities.js
         */

        if (!hasHeaderSection || !header?.hasAttribute('transparent')) {
          document.body.style.setProperty('--transparent-header-offset-boolean', '0');
          return;
        }

        const hasImmediateSection = hasHeaderSection.nextElementSibling?.classList.contains('shopify-section');

        const shouldApplyOffset = !hasImmediateSection ? '1' : '0';
        document.body.style.setProperty('--transparent-header-offset-boolean', shouldApplyOffset);
      })();

      (function setHeaderMenuStyle() {
        const headerComponent = document.querySelector('#header-component');
        if (headerComponent) {
          const isTouchDevice = 'ontouchstart' in window && navigator.maxTouchPoints > 0;
          const overflowList = headerComponent?.querySelector('overflow-list');
          const hasReachedMinimum = overflowList && overflowList.hasAttribute('minimum-reached');
          headerComponent.dataset.menuStyle = isTouchDevice || hasReachedMinimum ? 'drawer' : 'menu';
        }
      })();
    </script>

    <main
      id="MainContent"
      class="content-for-layout"
      role="main"
      data-page-transition-enabled="{{ settings.page_transition_enabled }}"
      data-product-transition="{{ settings.transition_to_main_product }}"
      data-template="{{ template }}"
    >
      {{ content_for_layout }}
    </main>

    <footer>
      {% sections 'footer-group' %}
    </footer>

    {% render 'search-modal' %}

    {% if settings.quick_add or settings.mobile_quick_add %}
      {% render 'quick-add-modal' %}
    {% endif %}
  </body>
</html>

{%- doc -%}
  Renders a default variant picker, used to display the variant picker in the variants block.

  @param {object} product_resource - The product object.
  @param {object} [block] - The block object
  @param {object} section - The section object.
  @param {object} product - The current product object (used to determine selected variant state).
{%- enddoc -%}

{% assign block_settings = block.settings %}

{%- assign has_any_size_chart = false -%}
{%- if product_resource.metafields.custom.shirt_size_chart.value != blank or product_resource.metafields.custom.bottom_size_chart.value != blank or product_resource.metafields.custom.size_chart.value != blank -%}
  {%- assign has_any_size_chart = true -%}
{%- endif -%}

{% unless product_resource.has_only_default_variant %}
  {% liquid
    assign button_background_brightness = section.settings.color_scheme.settings.foreground | color_brightness
    if button_background_brightness < 105
      assign strikethrough_color_mix = '#000'
    else
      assign strikethrough_color_mix = '#fff'
    endif
  %}
  <variant-picker
    class="variant-picker spacing-style variant-picker--{{ block_settings.alignment }}"
    style="--color-strikethrough-mix: {{ strikethrough_color_mix }}; {% render 'spacing-style', settings: block_settings %}"
    data-section-id="{{ section.id }}"
    data-product-id="{{ product_resource.id }}"
    data-block-id="{{ block.id }}"
    data-product-url="{{ product_resource.url }}"
    ref="mainVariantPicker"
    {% if product.id == product_resource.id %}
      data-template-product-match="true"
    {% endif %}
    {{ block.shopify_attributes }}
    {% if request.visual_preview_mode %}
      data-shopify-visual-preview
    {% endif %}
  >
    <form class="variant-picker__form">
      {%- for product_option in product_resource.options_with_values -%}
        {%- liquid
          assign swatch_count = product_option.values | map: 'swatch' | compact | size
          assign option_name_downcase = product_option.name | downcase
          if swatch_count == 0 and block_settings.show_swatches
            if option_name_downcase == 'color' or option_name_downcase == 'colour'
              assign swatch_count = 1
            endif
          endif
          assign variant_style = block_settings.variant_style

          if swatch_count > 0 and block_settings.show_swatches
            if block_settings.variant_style == 'dropdown'
              assign variant_style = 'swatch_dropdown'
            else
              assign variant_style = 'swatch'
            endif
          endif

          if variant_style == 'buttons' and settings.variant_button_width == 'equal-width-buttons'
            assign fieldset_id = section.id | append: '-' | append: product_resource.id | append: '-' | append: product_option.name | handleize
            assign option_id_attribute = 'data-option-id="' | append: fieldset_id | append: '"'
            assign longest_value = 0
          endif
        -%}

        {%- if product_option.values.size == 1 and variant_style != 'swatch' -%}
          <div
            class="variant-option"
            data-testid="variant-option-single"
          >
            <div class="variant-option__legend-header" style="width: 100%;">
              <span>
                {{- product_option.name | escape -}}:
                <span
                  class="variant-option__swatch-value"
                  data-testid="variant-option-single-value"
                >
                  {{- product_option.selected_value -}}
                </span>
              </span>
              {%- assign option_name_downcase = product_option.name | downcase -%}
              {%- if option_name_downcase == 'size' -%}
                {%- if has_any_size_chart -%}
                  <button
                    type="button"
                    class="size-chart-trigger"
                    aria-haspopup="dialog"
                    data-size-chart-trigger
                    data-product-id="{{ product_resource.id }}"
                  >
                    <svg class="icon-ruler" viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M21.3 15.3a2.82 2.82 0 0 1 0 4c-1 1-2.5 1-3.5 0L2.3 3.8a2.82 2.82 0 0 1 0-4c1-1 2.5-1 3.5 0Z"/>
                      <path d="m5.6 7.2 1.4-1.4"/>
                      <path d="m7.2 10.4 1.4-1.4"/>
                      <path d="m10.4 12 1.4-1.4"/>
                      <path d="m12 15.2 1.4-1.4"/>
                      <path d="m15.2 16.8 1.4-1.4"/>
                    </svg>
                    <span>Size Chart</span>
                  </button>
                {%- endif -%}
              {%- endif -%}
            </div>
          </div>
        {%- elsif variant_style == 'swatch' or block_settings.variant_style == 'buttons' -%}
          {%- assign fieldset_index = forloop.index0 -%}
          <fieldset
            class="variant-option variant-option--buttons{% if variant_style == 'swatch' %} variant-option--swatches{% else %} variant-option--{{ settings.variant_button_width }}{% endif %}"
            data-fieldset-index="{{ fieldset_index }}"
            ref="fieldsets[]"
            {{ option_id_attribute }}
          >
            <legend style="width: 100%;">
              <div class="variant-option__legend-header">
                <span>
                  {{ product_option.name | escape }}:
                  <span class="variant-option__swatch-value">{{ product_option.selected_value }}</span>
                </span>
                {%- if option_name_downcase == 'size' -%}
                  {%- if has_any_size_chart -%}
                    <button
                      type="button"
                      class="size-chart-trigger"
                      aria-haspopup="dialog"
                      data-size-chart-trigger
                      data-product-id="{{ product_resource.id }}"
                    >
                      <svg class="icon-ruler" viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21.3 15.3a2.82 2.82 0 0 1 0 4c-1 1-2.5 1-3.5 0L2.3 3.8a2.82 2.82 0 0 1 0-4c1-1 2.5-1 3.5 0Z"/>
                        <path d="m5.6 7.2 1.4-1.4"/>
                        <path d="m7.2 10.4 1.4-1.4"/>
                        <path d="m10.4 12 1.4-1.4"/>
                        <path d="m12 15.2 1.4-1.4"/>
                        <path d="m15.2 16.8 1.4-1.4"/>
                      </svg>
                      <span>Size Chart</span>
                    </button>
                  {%- endif -%}
                {%- endif -%}
              </div>
            </legend>
            {%- for product_option_value in product_option.values -%}
              {% if product_option_value.size > longest_value and option_id_attribute %}
                {% assign longest_value = product_option_value.size %}
              {% endif %}
              <label
                class="variant-option__button-label{% if variant_style == 'swatch' %} variant-option__button-label--has-swatch{% endif %}"
              >
                <input
                  type="radio"
                  name="{{ product_option.name | escape }}-{{ block.id }}-{{ product_resource.id }}"
                  value="{{ product_option_value | escape }}"
                  aria-label="{{ product_option_value.name | escape }}{% if product_option_value.available == false %} - {{ 'products.product.sold_out' | t }}{% endif %}"
                  {% if product_option_value.available == false %}
                    aria-disabled="true"
                  {% endif %}
                  data-previous-checked="false"
                  data-fieldset-index="{{ fieldset_index }}"
                  data-input-index="{{ forloop.index0 }}"
                  data-input-id="{{ product_option.position }}-{{ forloop.index0 }}"
                  data-option-value-id="{{ product_option_value.id }}"
                  data-option-available="{{ product_option_value.available }}"
                  data-connected-product-url="{{ product_option_value.product_url }}"
                  {% if product_option_value.variant.id %}
                    data-variant-id="{{ product_option_value.variant.id }}"
                  {% endif %}
                  {% if product_option_value.selected %}
                    data-current-checked="true"
                    checked
                  {% else %}
                    data-current-checked="false"
                  {% endif %}
                >
                {% if variant_style == 'swatch' %}
                  {% liquid
                    assign featured_media = product_option_value.variant.featured_media

                    # If the variant has no featured media, and we have a combined listing product, then fall back to
                    # using the featured media of the child product that is linked to this option value.
                    if featured_media == blank and product_option_value.product_url
                      assign featured_media = product_option_value.variant.product.featured_media
                    endif
                  %}

                  {% render 'swatch',
                    swatch: product_option_value.swatch,
                    variant_image: featured_media,
                    mode: 'unscaled',
                    value: product_option_value.name
                  %}
                {% else %}
                  {% if product_option_value.available == true %}
                    <span
                      class="variant-option__button-label__pill"
                      data-key="variant-option-pill"
                    ></span>
                  {% endif %}
                  <span
                    class="variant-option__button-label__text"
                    data-key="variant-option-text"
                  >
                    {{- product_option_value | escape -}}
                  </span>
                {% endif %}
                {% render 'strikethrough-variant', product_option: product_option_value %}
              </label>
            {%- endfor -%}
            {% if option_id_attribute %}
              {% style %}
                [data-option-id="{{ fieldset_id }}"] {
                  --variant-ch: {{ longest_value | times: 0.65 }}em;
                }
              {% endstyle %}
            {% endif %}
          </fieldset>
        {%- elsif block_settings.variant_style == 'dropdowns' -%}
          {%
            # There is an opportunity to build a custom select component that will allow us to style the select element further (animation for dropdown, swatches shown in the dropdown options, etc)
            # It's too bad as it mean rebuilding baked in behaviours but I think we've already done that for the locale selectors
            # in dawn. So it might mean more time spent in setting it up but worth it for future updates/styling.
          %}
          {% liquid
            assign property_being_updated = false
            if settings.variant_swatch_width != settings.variant_swatch_height
              assign property_being_updated = true
              # (original width / original height) x new height (20px at the moment) = new width
              assign new_width = settings.variant_swatch_width | times: 1.0 | divided_by: settings.variant_swatch_height | times: 20
            endif
          %}

          <div class="variant-option variant-option--dropdowns">
            <div class="variant-option__legend-header" style="width: 100%;">
              <label for="Option-{{ block.id }}-{{ forloop.index0 }}">{{ product_option.name | escape }}</label>
              {%- if option_name_downcase == 'size' -%}
                {%- if has_any_size_chart -%}
                  <button
                    type="button"
                    class="size-chart-trigger"
                    aria-haspopup="dialog"
                    data-size-chart-trigger
                    data-product-id="{{ product_resource.id }}"
                  >
                    <svg class="icon-ruler" viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M21.3 15.3a2.82 2.82 0 0 1 0 4c-1 1-2.5 1-3.5 0L2.3 3.8a2.82 2.82 0 0 1 0-4c1-1 2.5-1 3.5 0Z"/>
                      <path d="m5.6 7.2 1.4-1.4"/>
                      <path d="m7.2 10.4 1.4-1.4"/>
                      <path d="m10.4 12 1.4-1.4"/>
                      <path d="m12 15.2 1.4-1.4"/>
                      <path d="m15.2 16.8 1.4-1.4"/>
                    </svg>
                    <span>Size Chart</span>
                  </button>
                {%- endif -%}
              {%- endif -%}
            </div>
            <div
              class="variant-option__select-wrapper"
              style="
                {%- if property_being_updated  -%}
                  --variant-picker-swatch-width: clamp(10px,{{ new_width }}px, 50px);
                {%- endif -%}
              "
            >
              <select
                id="Option-{{ block.id }}-{{ forloop.index0 }}"
                name="options[{{ product_option.name | escape }}]"
                class="variant-option__select"
              >
                {%- for product_option_value in product_option.values -%}
                  <option
                    value="{{ product_option_value | escape }}"
                    data-input-id="{{ product_option.position }}-{{ forloop.index0 }}"
                    data-option-value-id="{{ product_option_value.id }}"
                    data-variant-id="{{ product_option_value.variant.id }}"
                    data-connected-product-url="{{ product_option_value.product_url }}"
                    {% if product_option_value.selected %}
                      selected="selected"
                    {% endif %}
                  >
                    {% if product_option_value.available == false %}
                      {{ product_option_value | escape }} - {{ 'content.unavailable' | t }}
                    {% else %}
                      {{ product_option_value | escape }}
                    {% endif %}
                  </option>
                {%- endfor -%}
              </select>
              <svg
                aria-hidden="true"
                focusable="false"
                class="icon icon-caret"
                viewBox="0 0 10 6"
              >
                {%- render 'icon', icon: 'caret' -%}
              </svg>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}

      <script type="application/json">
        {{ product_resource.selected_or_first_available_variant | json }}
      </script>
    </form>
    {%- assign has_size_option = false -%}
    {%- for option in product_resource.options_with_values -%}
      {%- assign option_name_downcase = option.name | downcase -%}
      {%- if option_name_downcase == 'size' -%}
        {%- assign has_size_option = true -%}
      {%- endif -%}
    {%- endfor -%}

    {%- if has_size_option and has_any_size_chart -%}
      <div class="size-chart-modal-wrapper" data-product-id="{{ product_resource.id }}">
        <dialog
          id="SizeChartModal-{{ block.id }}-{{ product_resource.id }}"
          class="size-chart-modal"
          role="dialog"
          aria-modal="true"
          aria-label="Size Chart"
        >
          <div class="size-chart-modal__inner">
            <div class="size-chart-modal__header">
              <h3 class="size-chart-modal__title">Size Chart</h3>
              <button
                type="button"
                class="size-chart-modal__close-btn"
                aria-label="Close size chart"
                data-size-chart-close
              >
                <svg class="icon icon-close" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="18" y1="6" x2="6" y2="18"></line>
                  <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
              </button>
            </div>
            <div class="size-chart-modal__body">
              {%- assign shirt_size_chart_val = product_resource.metafields.custom.shirt_size_chart.value -%}
              {%- assign bottom_size_chart_val = product_resource.metafields.custom.bottom_size_chart.value -%}

              {%- if shirt_size_chart_val != blank or bottom_size_chart_val != blank -%}
                <script class="shirt-size-chart-data" type="application/json">
                  {{ shirt_size_chart_val | json }}
                </script>
                <script class="bottom-size-chart-data" type="application/json">
                  {{ bottom_size_chart_val | json }}
                </script>
                <div class="size-chart-dynamic-tables">
                  <!-- JS will dynamically populate tables here -->
                </div>
              {%- elsif product_resource.metafields.custom.size_chart.value != blank -%}
                {%- assign size_chart_img = product_resource.metafields.custom.size_chart.value -%}
                {%- assign size_chart_alt = 'Size chart for ' | append: product_resource.title -%}
                <div class="size-chart-modal__image-card" style="display: flex; justify-content: center; align-items: center; width: 100%;">
                  {{ size_chart_img | image_url: width: 1000 | image_tag: loading: 'lazy', alt: size_chart_alt, style: 'max-width: 100%; height: auto; display: block; border-radius: 4px;' }}
                </div>
              {%- else -%}
                <div class="size-chart-modal__table-container">
                  {%- assign product_type_downcase = product_resource.type | downcase -%}
                  {%- assign product_title_downcase = product_resource.title | downcase -%}
                  
                  {%- if product_type_downcase contains 'jeans' or product_title_downcase contains 'jeans' or product_type_downcase contains 'pants' or product_title_downcase contains 'pants' -%}
          
                  {%- else -%}
                    <table class="size-chart-table">
                      <thead>
                        <tr>
                          <th>Size</th>
                          <th>Length</th>
                          <th>Chest (Width)</th>
                          <th>Shoulder</th>
                          <th>Sleeve Length</th>
                        </tr>
                      </thead>
                      <tbody>
                        <tr>
                          <td>S</td>
                          <td class="size-val" data-cm="70" data-inch="27.5">70</td>
                          <td class="size-val" data-cm="100" data-inch="39.4">100</td>
                          <td class="size-val" data-cm="44" data-inch="17.3">44</td>
                          <td class="size-val" data-cm="61" data-inch="24.0">61</td>
                        </tr>
                        <tr>
                          <td>M</td>
                          <td class="size-val" data-cm="72" data-inch="28.3">72</td>
                          <td class="size-val" data-cm="106" data-inch="41.7">106</td>
                          <td class="size-val" data-cm="46" data-inch="18.1">46</td>
                          <td class="size-val" data-cm="62" data-inch="24.4">62</td>
                        </tr>
                        <tr>
                          <td>L</td>
                          <td class="size-val" data-cm="74" data-inch="29.1">74</td>
                          <td class="size-val" data-cm="112" data-inch="44.1">112</td>
                          <td class="size-val" data-cm="48" data-inch="18.9">48</td>
                          <td class="size-val" data-cm="63" data-inch="24.8">63</td>
                        </tr>
                        <tr>
                          <td>XL</td>
                          <td class="size-val" data-cm="76" data-inch="29.9">76</td>
                          <td class="size-val" data-cm="118" data-inch="46.5">118</td>
                          <td class="size-val" data-cm="50" data-inch="19.7">50</td>
                          <td class="size-val" data-cm="64" data-inch="25.2">64</td>
                        </tr>
                        <tr>
                          <td>2XL</td>
                          <td class="size-val" data-cm="78" data-inch="30.7">78</td>
                          <td class="size-val" data-cm="124" data-inch="48.8">124</td>
                          <td class="size-val" data-cm="52" data-inch="20.5">52</td>
                          <td class="size-val" data-cm="65" data-inch="25.6">65</td>
                        </tr>
                        <tr>
                          <td>3XL</td>
                          <td class="size-val" data-cm="80" data-inch="31.5">80</td>
                          <td class="size-val" data-cm="130" data-inch="51.2">130</td>
                          <td class="size-val" data-cm="54" data-inch="21.3">54</td>
                          <td class="size-val" data-cm="66" data-inch="26.0">66</td>
                        </tr>
                      </tbody>
                    </table>
                  {%- endif -%}
                </div>
              {%- endif -%}
            </div>
          </div>
        </dialog>
      </div>
    {%- endif -%}

    <script type="application/json" data-variant-inventory-json>
      {
        {%- for variant in product_resource.variants -%}
          "{{ variant.id }}": {
            "inventory_quantity": {{ variant.inventory_quantity | default: 0 }},
            "inventory_management": "{{ variant.inventory_management }}",
            "inventory_policy": "{{ variant.inventory_policy }}"
          }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      }
    </script>
    
    <div class="variant-picker__inventory-status" data-variant-inventory-status style="display: none; align-items: center; gap: 8px; margin-block: var(--margin-xs); font-size: 13px; font-weight: 500;">
      <svg class="icon icon-inventory-fire" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: currentColor;">
        <path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"></path>
      </svg>
      <span class="inventory-status-text"></span>
    </div>
  </variant-picker>
{% endunless %}

{% stylesheet %}
  /* Variant picker container styles - unique to main variant picker */
  .variant-picker {
    width: 100%;
    padding-top: 0px; 
  }

  .variant-picker__form {
    width: 100%;
  }

  .variant-picker[data-shopify-visual-preview] {
    min-width: 300px;
    padding-inline-start: max(4px, var(--padding-inline-start));
  }

  /* Dropdown variant option styles */
  .variant-option__select-wrapper {
    display: flex;
    position: relative;
    border: var(--style-border-width-inputs) solid var(--color-border);
    border-radius: var(--style-border-radius-inputs);
    align-items: center;
    margin-top: var(--margin-2xs);
    overflow: clip;
  }

  .variant-option__select-wrapper:has(.swatch) {
    --variant-picker-swatch-width: 20px;
    --variant-picker-swatch-height: 20px;
  }

  .variant-option__select-wrapper:hover {
    border-color: var(--color-variant-hover-border);
  }

  .variant-option__select:focus-visible {
    outline: var(--focus-outline-width) solid currentcolor;
    outline-offset: var(--focus-outline-offset);
  }

  .variant-option__select {
    padding-block: var(--padding-md);
    padding-inline: var(--padding-lg) calc(var(--padding-lg) + var(--icon-size-2xs));
    appearance: none;
    border: 0;
    width: 100%;
    margin: 0;
    cursor: pointer;
  }

  .variant-option__select-wrapper .icon {
    position: absolute;
    right: var(--padding-md);
    top: 50%;
    transform: translateY(-50%);
    width: var(--icon-size-2xs);
    height: var(--icon-size-2xs);
    pointer-events: none;
  }

  .variant-option__select--has-swatch {
    padding-inline-start: calc((2 * var(--padding-sm)) + var(--variant-picker-swatch-width));
  }

  .variant-option__select-wrapper .swatch {
    position: absolute;
    top: 50%;
    left: var(--padding-md);
    transform: translateY(-50%);
  }

  /* Variant picker alignment modifiers */
  .variant-picker--center,
  .variant-picker--center .variant-option {
    text-align: center;
    align-items: center;
    justify-content: center;
    width: 100%;
  }

  .variant-picker--right,
  .variant-picker--right .variant-option {
    text-align: right;
    justify-content: right;
  }

  /* Size Chart Trigger & Modal Styles */
  .variant-option__legend-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    font-size: 14px;
    margin-bottom: var(--margin-xs);
  }

  .variant-option__legend-header:has(.size-chart-trigger) {
    justify-content: space-between;
    gap: 12px;
  }

  .variant-option--buttons legend {
    margin-block-end: 0 !important;
    width: 100%;
  }

  .size-chart-trigger {
    background: transparent !important;
    border: none !important;
    padding: 0 !important;
    box-shadow: none !important;
    border-radius: 0 !important;
    cursor: pointer;
    font-family: var(--font-body--family);
    font-size: 13px;
    font-weight: 500;
    color: var(--color-foreground);
    display: inline-flex;
    align-items: center;
    gap: 6px;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s ease;
  }

  .size-chart-trigger:hover {
    color: var(--color-copper-rivet, #b87333);
  }

  .size-chart-trigger svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  @keyframes sizeChartFadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes sizeChartFadeOut {
    from { opacity: 1; }
    to { opacity: 0; }
  }

  @keyframes sizeChartZoomIn {
    from { transform: scale(0.96); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }

  @keyframes sizeChartZoomOut {
    from { transform: scale(1); opacity: 1; }
    to { transform: scale(0.96); opacity: 0; }
  }

  @keyframes sizeChartSlideUp {
    from { transform: translateY(100%); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  @keyframes sizeChartSlideDown {
    from { transform: translateY(0); opacity: 1; }
    to { transform: translateY(100%); opacity: 0; }
  }

  .size-chart-modal {
    border: none;
    border-radius: 8px;
    background: #ffffff;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
    padding: 0;
    max-width: min(640px, 90vw);
    width: 100%;
    max-height: 85vh;
    box-sizing: border-box;
    margin: auto;
    overflow: hidden;
  }

  .size-chart-modal[open] {
    opacity: 1;
    pointer-events: auto;
    animation: sizeChartZoomIn 0.25s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .size-chart-modal.dialog-closing {
    animation: sizeChartZoomOut 0.25s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @media screen and (max-width: 749px) {
    .size-chart-modal {
      position: fixed;
      inset: auto 0 0 0;
      margin: 0;
      width: 100%;
      max-width: 100%;
      height: 70vh;
      max-height: 85vh;
      border-radius: 16px 16px 0 0;
      transform: translateY(100%);
      opacity: 0;
    }

    .size-chart-modal[open] {
      transform: translateY(0);
      opacity: 1;
      animation: sizeChartSlideUp 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    .size-chart-modal.dialog-closing {
      animation: sizeChartSlideDown 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
  }

  .size-chart-modal::backdrop {
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(2px);
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .size-chart-modal[open]::backdrop {
    animation: sizeChartFadeIn 0.25s ease forwards;
  }

  .size-chart-modal.dialog-closing::backdrop {
    animation: sizeChartFadeOut 0.25s ease forwards;
  }

  .size-chart-modal__inner {
    display: flex;
    flex-direction: column;
    max-height: 85vh;
    box-sizing: border-box;
  }

  @media screen and (max-width: 749px) {
    .size-chart-modal__inner {
      max-height: 70vh;
    }
  }

  .size-chart-modal__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid #e5e5e5;
    padding: 16px 20px;
    background: #ffffff;
  }

  .size-chart-modal__title {
    font-family: var(--font-heading) !important;
    font-size: 18px;
    font-weight: 500;
    color: var(--color-foreground, #222222);
    margin: 0;
  }

  .size-chart-modal__close-btn {
    background: none;
    border: none;
    padding: 6px;
    cursor: pointer;
    color: var(--color-foreground, #222222);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    transition: background-color 0.2s;
  }

  .size-chart-modal__close-btn:hover {
    background-color: #f0f0f0;
  }

  .size-chart-modal__body {
    padding: 20px;
    overflow-y: auto;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
  }

  .size-chart-modal__tabs {
    display: flex;
    gap: 8px;
    margin-bottom: 16px;
    border-bottom: 1px solid var(--color-border, #e5e5e5);
    padding-bottom: 12px;
  }

  .size-chart-unit-btn {
    background: none;
    border: none;
    padding: 6px 14px;
    cursor: pointer;
    font-family: var(--font-body--family);
    font-size: 13px;
    font-weight: 500;
    color: var(--color-foreground-secondary, #666);
    border-radius: 4px;
    transition: all 0.2s ease;
  }

  .size-chart-unit-btn:hover {
    background-color: var(--color-background-secondary, #f5f5f5);
    color: var(--color-foreground);
  }

  .size-chart-unit-btn.active {
    background-color: var(--color-foreground, #222);
    color: var(--color-background, #fff);
  }

  .size-chart-modal__table-container {
    overflow-x: auto;
    width: 100%;
    border-radius: var(--style-border-radius-inputs, 4px);
    border: 1px solid var(--color-border, #e5e5e5);
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
  }

  .size-chart-table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-body--family);
    font-size: 13px;
    line-height: 1.5;
    text-align: left;
  }

  .size-chart-table th,
  .size-chart-table td {
    padding: 10px 14px;
    border-bottom: 1px solid var(--color-border, #e5e5e5);
  }

  .size-chart-table th {
    font-weight: 600;
    color: var(--color-foreground);
    background-color: var(--color-background-secondary, #f9f9f9);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .size-chart-table td {
    color: var(--color-foreground);
  }

  .size-chart-table tbody tr:nth-child(even) {
    background-color: var(--color-background-secondary, #fafafa);
  }

  .size-chart-table tbody tr:last-child td {
    border-bottom: none;
  }

  .size-chart-table tbody tr:hover {
    background-color: var(--color-background-secondary, #fafafa);
  }

  .size-chart-dynamic-tables {
    display: flex;
    flex-direction: column;
    width: 100%;
    gap: 20px;
  }

  .size-chart-dynamic-section {
    width: 100%;
  }

  .size-chart-fit-title {
    font-family: var(--font-heading) !important;
    font-size: 16px;
    font-weight: 500;
    color: var(--color-foreground);
    margin-top: 0;
    margin-bottom: 10px;
  }
{% endstylesheet %}

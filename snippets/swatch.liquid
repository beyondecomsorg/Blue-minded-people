{%- doc -%}
  Renders a swatch either from a variant image object or a swatch object.

  @param {object} swatch - a swatch object
  @param {object} [variant_image] - an alternate image when there is no swatch value
  @param {string} [mode] - one of 'unscaled', 'filter', 'pill'
  @param {string} [label] - visually-hidden accessible label for the swatch (e.g. the color name)

  @example
  {% render 'swatch', swatch: swatch, variant_image: variant_image, mode: 'unscaled', label: option_value.name %}
{%- enddoc -%}

{% liquid
  assign swatch_value = null
  assign extra_classes = ''
  if settings.show_variant_image and variant_image
    assign swatch_image_width = settings.variant_swatch_width | times: 2
    assign swatch_image_url = variant_image | image_url: width: swatch_image_width
    assign swatch_value = 'url(' | append: swatch_image_url | append: ')'
    assign extra_classes = extra_classes | append: ' swatch--variant-image'
  elsif swatch.image
    assign swatch_image_url = swatch.image | image_url: width: 80
    assign swatch_value = 'url(' | append: swatch_image_url | append: ')'
  elsif swatch.color
    assign swatch_value = 'rgb(' | append: swatch.color.rgb | append: ')'
  endif

  assign swatch_name = value | default: label
  if swatch_value == null and swatch_name != blank
    assign color_name = swatch_name | downcase | strip
    
    # 1. Check custom theme setting color mapping first
    if settings.swatch_color_mapping != blank
      assign mappings = settings.swatch_color_mapping | newline_to_br | split: '<br />'
      for mapping in mappings
        assign parts = mapping | split: ':'
        if parts.size >= 2
          assign map_name = parts[0] | downcase | strip
          assign map_val = parts[1] | strip
          if map_name == color_name
            assign swatch_value = map_val
            break
          endif
        endif
      endfor
    endif

    # 2. Fallback case statement
    if swatch_value == null
      case color_name
        when 'deep navy', 'navy'
          assign swatch_value = 'var(--color-deep-navy)'
        when 'indigo blue', 'indigo'
          assign swatch_value = 'var(--color-indigo-blue)'
        when 'off white', 'white'
          assign swatch_value = 'var(--color-off-white)'
        when 'raw denim blue', 'raw denim', 'denim'
          assign swatch_value = 'var(--color-raw-denim-blue)'
        when 'vintage stone', 'stone'
          assign swatch_value = 'var(--color-vintage-stone)'
        when 'charcoal grey', 'charcoal gray', 'charcoal'
          assign swatch_value = 'var(--color-charcoal-grey)'
        when 'medium grey', 'medium gray', 'grey', 'gray'
          assign swatch_value = 'var(--color-medium-grey)'
        when 'border grey', 'border gray'
          assign swatch_value = 'var(--color-border-grey)'
        when 'copper rivet', 'copper'
          assign swatch_value = 'var(--color-copper-rivet)'
        else
          if variant_image
            assign swatch_image_width = settings.variant_swatch_width | default: 32 | times: 2
            assign swatch_image_url = variant_image | image_url: width: swatch_image_width
            assign swatch_value = 'url(' | append: swatch_image_url | append: ')'
            assign extra_classes = extra_classes | append: ' swatch--variant-image'
          else
            assign swatch_value = color_name
          endif
      endcase
    endif
  endif

  case mode
    when 'unscaled'
      assign extra_classes = extra_classes | append: ' swatch--unscaled'
    when 'filter'
      assign extra_classes = extra_classes | append: ' swatch--filter'
    when 'pill'
      assign extra_classes = extra_classes | append: ' swatch--pill'
  endcase
%}

<span
  class="
    swatch
    {{ extra_classes }}
    {% if swatch_value == null %} swatch--unavailable{% endif %}
  "
  style="
    --swatch-background: {{ swatch_value }};
    {% if swatch.image and settings.show_variant_image == false %} --swatch-focal-point: {{ swatch.image.presentation.focal_point }};{% endif %}
  "
>
</span>
{%- if label != blank -%}
  <span class="visually-hidden">{{ label }}</span>
{%- endif -%}

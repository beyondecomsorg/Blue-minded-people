

{% liquid
  assign block_settings = block.settings
  assign use_inverse_logo = false

  if section.settings.enable_transparent_header_home and template.name == 'index' and section.settings.home_color_scheme == 'inverse'
    assign use_inverse_logo = true
  elsif section.settings.enable_transparent_header_product and template.name == 'product' and section.settings.product_color_scheme == 'inverse'
    assign use_inverse_logo = true
  elsif section.settings.enable_transparent_header_collection and template.name == 'collection' and section.settings.collection_color_scheme == 'inverse'
    assign use_inverse_logo = true
  endif

  # Always resolve inverse_logo so both containers can be rendered.
  # Priority: dedicated inverse logo → fall back to the default logo.
  # This ensures the CSS :has() guard works correctly on dark/transparent headers.
  if settings.logo_inverse != blank
    assign inverse_logo = settings.logo_inverse
  else
    assign inverse_logo = settings.logo
  endif

  assign alt_text_fallback = 'accessibility.home_logo_alt' | t: store_name: shop.name
%}

{% comment %}
  Output all logo variants, use CSS to hide/show the appropriate one
  based on the .header[transparent] selector.
  Both containers are always rendered so the :has() CSS guard functions
  correctly and --header-logo-display / --header-logo-inverse-display
  can toggle the correct logo on dark/navy/transparent backgrounds.
{% endcomment %}
<a
  {% if template.name == 'index' and block_settings.hide_logo_on_home_page %}
    data-hidden-on-home-page
  {% endif %}
  href="{{ routes.root_url }}"
  class="size-style spacing-style header-logo"
  style="
    {% render 'size-style', settings: block_settings %}
    {% render 'spacing-style', settings: block_settings %}
    --font-family: var(--font-body--family);
    --font-style: var(--font-body--style);
    --font-weight: 600;
  "
  {{ block.shopify_attributes }}
>
  {% liquid
    # Compute widths — guard against nil aspect_ratio (logo not yet uploaded)
    assign logo_aspect = settings.logo.aspect_ratio | default: 1
    assign inverse_aspect = inverse_logo.aspect_ratio | default: logo_aspect

    assign logo_width = settings.logo_height | times: logo_aspect | ceil
    assign logo_width_mobile = settings.logo_height_mobile | times: logo_aspect | ceil
    assign inverse_logo_width = settings.logo_height | times: inverse_aspect | ceil
    assign inverse_logo_width_mobile = settings.logo_height_mobile | times: inverse_aspect | ceil

    assign logo_style = '--header-logo-image-width: ' | append: logo_width | append: 'px; --header-logo-image-width-mobile: ' | append: logo_width_mobile | append: 'px; --header-logo-image-height: ' | append: settings.logo_height | append: 'px; --header-logo-image-height-mobile: ' | append: settings.logo_height_mobile | append: 'px;'
    assign inverse_logo_style = '--header-logo-image-width: ' | append: inverse_logo_width | append: 'px; --header-logo-image-width-mobile: ' | append: inverse_logo_width_mobile | append: 'px; --header-logo-image-height: ' | append: settings.logo_height | append: 'px; --header-logo-image-height-mobile: ' | append: settings.logo_height_mobile | append: 'px;'
  %}

  <span
    class="header-logo__image-container header-logo__image-container--original"
    data-testid="header-logo"
  >
    {% render 'image',
      image: settings.logo,
      class: 'header-logo__image',
      height: settings.logo_height,
      alt_text_fallback: alt_text_fallback,
      text_fallback: shop.name,
      style: logo_style
    %}
  </span>

  {% comment %}
    Always render the inverse container so the CSS :has() guard works.
    When use_inverse_logo is false (non-transparent header), the container
    is rendered but hidden via --header-logo-inverse-display: none.
    When transparent + inverse mode is active, it becomes visible.
  {% endcomment %}
  <span
    class="header-logo__image-container header-logo__image-container--inverse{% unless use_inverse_logo %} header-logo__image-container--inverse-fallback{% endunless %}"
    data-testid="header-logo-inverse"
  >
    {% render 'image',
      image: inverse_logo,
      class: 'header-logo__image',
      height: settings.logo_height,
      alt_text_fallback: alt_text_fallback,
      text_fallback: shop.name,
      style: inverse_logo_style
    %}
  </span>
</a>

{% stylesheet %}
  .header-logo {
    display: flex;
    height: 100%;
    font-size: var(--font-size--md);
    font-family: var(--font-family);
    font-weight: var(--font-weight);
    font-style: var(--font-style);
    color: var(--color-foreground);
    justify-content: center;
    align-items: center;
    text-decoration: none;

    &[data-hidden-on-home-page] {
      display: none;

      #header-component:is(
          [sticky='always']:not([data-scroll-direction='none']),
          [sticky='scroll-up'][data-scroll-direction='up']
        )
        & {
        display: flex;
      }
    }

    @media screen and (max-width: 749px) {
      padding: 0;
    }

    @media screen and (min-width: 750px) {
      flex-shrink: 0;
    }

    &:hover {
      text-decoration: none;
    }
  }

  .header-logo__image {
    object-fit: contain;
    /* Guard: fall back to auto if the CSS variable is empty / zero */
    height: var(--header-logo-image-height-mobile, auto);
    width: var(--header-logo-image-width-mobile, auto);
    max-height: 80px; /* safety cap so a 0-height var doesn't collapse the image */

    @media screen and (min-width: 750px) {
      height: var(--header-logo-image-height, auto);
      width: var(--header-logo-image-width, auto);
    }
  }

  /*
   * Logo visibility logic:
   * - Both containers are always in the DOM (see Liquid above).
   * - On non-transparent headers: original = block, inverse = none.
   * - On transparent/inverse headers: CSS vars flip them via --header-logo-display
   *   and --header-logo-inverse-display (set in header.liquid stylesheet).
   * - The --inverse-fallback class marks containers that re-use the default logo;
   *   they follow the same toggle so switching colour schemes still works.
   */
  .header-logo:has(.header-logo__image-container--inverse) .header-logo__image-container--original {
    display: var(--header-logo-display, block);
  }

  .header-logo__image-container--inverse {
    display: var(--header-logo-inverse-display, none);
  }

  /*
   * Safety override: when the header is NOT transparent (no [transparent] attr)
   * always force the original logo visible and the inverse hidden,
   * regardless of any lingering CSS variable values.
   */
  #header-component:not([transparent]) .header-logo__image-container--original {
    display: block !important;
  }

  #header-component:not([transparent]) .header-logo__image-container--inverse {
    display: none !important;
  }

  /*
   * When the transparent header becomes "sticky-active" (user scrolled),
   * both containers switch back to their natural display so the
   * theme colour scheme takes over cleanly.
   */
  #header-component[transparent='not-sticky'][data-sticky-state='active'] .header-logo__image-container--original,
  #header-component[transparent='always'][data-sticky-state='active'] .header-logo__image-container--original {
    display: block;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.logo",
  "tag": null,
  "class": "header-logo",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:content.edit_logo_in_theme_settings"
    },
    {
      "type": "header",
      "content": "t:content.visibility"
    },
    {
      "type": "checkbox",
      "id": "hide_logo_on_home_page",
      "label": "t:settings.hide_logo_on_home_page",
      "info": "t:info.hide_logo_on_home_page_help"
    },
    {
      "type": "header",
      "content": "t:content.padding_desktop"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ]
}
{% endschema %}

{% comment %}
  What's New Today — MR PORTER style section
  Customization: Text, Background, Section Padding
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} {
    background-color: var(--color-off-white);
    padding-top: var(--global-section-padding-top-mobile);
    padding-bottom: var(--global-section-padding-bottom-mobile);
  }
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} {
      padding-top: var(--global-section-padding-top-desktop);
      padding-bottom: var(--global-section-padding-bottom-desktop);
    }
  }

  .wnt-wrapper {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    gap: 40px;
  }

  /* Left panel */
  .wnt-left {
    flex: 0 0 220px;
    min-width: 180px;
  }

  .wnt-eyebrow {
    font-family: var(--font-body--family);
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-deep-navy);
    margin: 0 0 12px;
  }

  .wnt-count {
    font-family: var(--font-body--family);
    font-size: 72px;
    font-weight: 300;
    line-height: 1;
    color: var(--color-deep-navy);
    margin: 0 0 16px;
    letter-spacing: -0.02em;
  }

  .wnt-subtext {
    font-family: var(--font-body--family);
    font-size: 13px;
    color: var(--color-medium-grey);
    margin: 0 0 24px;
    line-height: 1.5;
  }

  .wnt-cta {
    display: inline-block;
    background-color: var(--color-copper-rivet);
    color: var(--color-off-white);
    font-family: var(--font-body--family);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 13px 24px;
    border: none;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .wnt-cta:hover {
    opacity: 0.8;
  }

  /* Products carousel */
  .wnt-products-outer {
    flex: 1;
    overflow: hidden;
    position: relative;
  }

  .wnt-products {
    display: flex;
    gap: 2px;
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
    scroll-snap-type: x mandatory;
  }

  .wnt-products::-webkit-scrollbar {
    display: none;
  }

  .wnt-product-item {
    flex: 0 0 calc(25% - 2px);
    min-width: 180px;
    scroll-snap-align: start;
    background: var(--color-off-white);
    position: relative;
  }

  .wnt-product-img-wrap {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: var(--color-off-white);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .wnt-product-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .wnt-product-brand {
    font-family: var(--font-body--family);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-charcoal-grey);
    text-align: center;
    padding: 10px 8px 8px;
  }

  /* Arrow nav */
  .wnt-arrow {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 36px;
    height: 36px;
    background: var(--color-off-white);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    box-shadow: -4px 0 12px rgba(0,0,0,0.06);
    transition: background 0.2s;
  }

  .wnt-arrow:hover {
    background: var(--color-border-grey);
  }

  .wnt-arrow svg {
    width: 16px;
    height: 16px;
    stroke: var(--color-deep-navy);
    fill: none;
    stroke-width: 1.5;
  }

  @media (max-width: 768px) {
    .wnt-wrapper {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
      padding: 0 16px;
    }

    .wnt-left {
      flex: none;
      width: 100%;
    }

    .wnt-count {
      font-size: 56px;
    }

    .wnt-products-outer {
      width: 100%;
    }

    .wnt-product-item {
      flex: 0 0 48%;
      min-width: 140px;
    }
  }
</style>

<div class="wnt-wrapper">
  <!-- Left Panel -->
  <div class="wnt-left">
    <p class="wnt-eyebrow">{{ section.settings.eyebrow_text }}</p>
    <div class="wnt-count">{{ section.settings.count_text }}</div>
    <p class="wnt-subtext">{{ section.settings.subtext }}</p>
    <a href="{{ section.settings.btn_url }}" class="wnt-cta">{{ section.settings.btn_label }}</a>
  </div>

  <!-- Products -->
  <div class="wnt-products-outer">
    <div class="wnt-products" id="wnt-track-{{ section.id }}">
      {% for block in section.blocks %}
        {% if block.type == 'product_card' %}
          <div class="wnt-product-item" {{ block.shopify_attributes }}>
            <a href="{{ block.settings.product_url }}" style="text-decoration:none;">
              <div class="wnt-product-img-wrap">
                {% if block.settings.product_image != blank %}
                  <img
                    src="{{ block.settings.product_image | img_url: '600x' }}"
                    alt="{{ block.settings.brand_name }}"
                    loading="lazy"
                    width="600"
                    height="800"
                  >
                {% else %}
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {% endif %}
              </div>
              <p class="wnt-product-brand">{{ block.settings.brand_name }}</p>
            </a>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <button class="wnt-arrow" id="wnt-next-{{ section.id }}" aria-label="Next">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>
  </div>
</div>

<script>
  (function() {
    var track = document.getElementById('wnt-track-{{ section.id }}');
    var btn = document.getElementById('wnt-next-{{ section.id }}');
    if (!track || !btn) return;

    btn.addEventListener('click', function() {
      var item = track.querySelector('.wnt-product-item');
      if (!item) return;
      var itemW = item.offsetWidth + 2; // +2 for gap
      var visible = Math.floor(track.offsetWidth / itemW);
      var maxScroll = track.scrollWidth - track.offsetWidth;

      // If at (or near) the end, jump back to start
      if (track.scrollLeft + track.offsetWidth >= track.scrollWidth - 8) {
        track.scrollTo({ left: 0, behavior: 'smooth' });
      } else {
        track.scrollBy({ left: itemW * visible, behavior: 'smooth' });
      }
    });
  })();
</script>

{% schema %}
{
  "name": "What's New Today",
  "tag": "section",
  "class": "whats-new-today",
  "settings": [
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Eyebrow Label",
      "default": "What's New Today"
    },
    {
      "type": "text",
      "id": "count_text",
      "label": "Count Number",
      "default": "448"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Discover what just landed at MR PORTER"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button Label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow Text Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "count_color",
      "label": "Count Number Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "subtext_color",
      "label": "Subtext Color",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "brand_label_color",
      "label": "Brand Name Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "btn_bg_color",
      "label": "Button Background",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Button Text Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "select",
      "id": "font_family",
      "label": "Font Family",
      "default": "inherit",
      "options": [
        { "value": "inherit", "label": "Theme Default" },
        { "value": "'Times New Roman', serif", "label": "Times New Roman" },
        { "value": "Georgia, serif", "label": "Georgia" },
        { "value": "Helvetica, Arial, sans-serif", "label": "Helvetica" },
        { "value": "Futura, 'Trebuchet MS', sans-serif", "label": "Futura" }
      ]
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "product_image",
          "label": "Product Image"
        },
        {
          "type": "text",
          "id": "brand_name",
          "label": "Brand Name",
          "default": "BRAND"
        },
        {
          "type": "url",
          "id": "product_url",
          "label": "Product URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "What's New Today",
      "blocks": [
        { "type": "product_card", "settings": { "brand_name": "ZEGNA" } },
        { "type": "product_card", "settings": { "brand_name": "MÉTIER" } },
        { "type": "product_card", "settings": { "brand_name": "THE ELDER STATESMAN" } },
        { "type": "product_card", "settings": { "brand_name": "TOM FORD" } },
        { "type": "product_card", "settings": { "brand_name": "LORO PIANA" } },
        { "type": "product_card", "settings": { "brand_name": "BRUNELLO" } }
      ]
    }
  ]
}
{% endschema %}

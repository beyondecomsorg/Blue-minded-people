  ],
  "blocks": [
    {
      "type": "category_card",
      "name": "Category Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "card_image",
          "label": "Card Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "MEN"
        },
        {
          "type": "url",
          "id": "card_url",
          "label": "Link URL"

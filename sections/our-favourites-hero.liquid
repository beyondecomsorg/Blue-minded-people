      "default": "Our Favourites"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Standout gifts with signature Ralph Lauren style"
    },
    {
      "type": "range",
      "id": "text_top",
      "label": "Text — Top Offset",
      "min": 10,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 28

    {
      "type": "range",
      "id": "section_min_height",
      "label": "Section Min Height",
      "min": 400,
      "max": 1000,
      "step": 10,
      "unit": "px",
      "default": 680
    },
    {
      "type": "range",
      "id": "overlay_top_opacity",
      "label": "Overlay Opacity (Top)",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 20
    },
    {
      "type": "range",
      "id": "overlay_bottom_opacity",
      "label": "Overlay Opacity (Bottom)",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "%",
      "default": 40
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section Outer Background",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Text Block"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "RALPH LAUREN"
    },
    {
      "type": "text",
      "id": "title",

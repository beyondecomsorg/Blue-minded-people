{% comment %}
  Our Favourites — Ralph Lauren style
  Full-width hero background + overlaid category cards with bottom label
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} {
    background-color: var(--color-off-white);
  }

  /* ── Hero wrapper ── */
  .orf-hero {
    position: relative;
    width: 100%;
    min-height: {{ section.settings.section_min_height }}px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  /* Hero BG image */
  .orf-hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .orf-hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  /* Overlay tint */
  .orf-hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to bottom,
      rgba(11,31,51,{{ section.settings.overlay_top_opacity | divided_by: 100.0 }}) 0%,
      rgba(11,31,51,{{ section.settings.overlay_bottom_opacity | divided_by: 100.0 }}) 100%
    );
  }

  /* ── Text block top-left ── */
  .orf-text {
    position: absolute;
    top: {{ section.settings.text_top }}px;
    left: {{ section.settings.text_left }}px;
    z-index: 3;
    max-width: 520px;
  }

  .orf-eyebrow {
    font-family: var(--font-body--family);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-off-white);
    margin: 0 0 10px;
    display: block;
  }

  .orf-title {
    font-family: var(--font-heading--family);
    font-size: var(--font-h1--size);
    line-height: var(--font-h1--line-height);
    letter-spacing: var(--font-h1--letter-spacing);
    font-weight: var(--font-h1--weight);
    color: var(--color-off-white);
    margin: 0 0 14px;
    text-transform: uppercase;
  }

  .orf-subtitle {
    font-family: var(--font-body--family);
    font-size: var(--font-paragraph--size);
    font-weight: 300;
    color: var(--color-vintage-stone);
    margin: 0;
    line-height: 1.5;
  }

  /* ── Cards row ── */
  .orf-cards {
    position: relative;
    z-index: 3;
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    gap: {{ section.settings.card_gap }}px;
    padding: {{ section.settings.cards_top_padding }}px {{ section.settings.cards_side_padding }}px {{ section.settings.cards_bottom_padding }}px;
    align-items: end;
  }

  .orf-card {
    display: block;
    text-decoration: none;
    position: relative;
    overflow: hidden;
    border: 1.5px solid var(--color-border-grey);
  }

  .orf-card-img {
    width: 100%;
    aspect-ratio: {{ section.settings.card_ratio }};
    overflow: hidden;
    display: block;
  }

  .orf-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
    transition: transform 0.5s ease;
  }

  .orf-card:hover .orf-card-img img {
    transform: scale(1.04);
  }

  /* Label bottom-left inside card */
  .orf-card-label {
    position: absolute;
    bottom: 14px;
    left: 14px;
    font-family: var(--font-body--family);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-off-white);
    text-shadow: 0 1px 6px rgba(0,0,0,0.5);
    line-height: 1;
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .orf-hero {
      min-height: auto;
    }

    .orf-text {
      position: relative;
      top: auto;
      left: auto;
      padding: 24px 20px 0;
    }

    .orf-cards {
      grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr);
      padding: 16px 12px 20px;
      gap: 8px;
    }

    .orf-card-label {
      bottom: 8px;
      left: 8px;
    }
  }
</style>

<div class="section-wrapper" style="--section-padding-top: {{ section.settings.padding_top }}px; --section-padding-bottom: {{ section.settings.padding_bottom }}px; --section-padding-top-mobile: {{ section.settings.padding_top_mobile }}px; --section-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;">
<div class="orf-hero">

  {%- if section.settings.bg_image != blank -%}
    <div class="orf-hero-bg">
      <img
        src="{{ section.settings.bg_image | img_url: '2000x' }}"
        alt="{{ section.settings.title }}"
        loading="eager"
        width="2000"
        height="1200"
      >
    </div>
  {%- else -%}
    <div class="orf-hero-bg" style="background: {{ section.settings.fallback_bg }};"></div>
  {%- endif -%}

  <div class="orf-hero-overlay"></div>

  <!-- Text top-left -->
  <div class="orf-text">
    {%- if section.settings.eyebrow != blank -%}
      <span class="orf-eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    {%- if section.settings.title != blank -%}
      <h2 class="orf-title">{{ section.settings.title }}</h2>
    {%- endif -%}
    {%- if section.settings.subtitle != blank -%}
      <p class="orf-subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}
  </div>

  <!-- Category cards -->
  <div class="orf-cards">
    {%- for block in section.blocks -%}
      {%- if block.type == 'category_card' -%}
        <a href="{{ block.settings.card_url }}" class="orf-card" {{ block.shopify_attributes }}>
          <div class="orf-card-img">
            {%- if block.settings.card_image != blank -%}
              <img
                src="{{ block.settings.card_image | img_url: '800x' }}"
                alt="{{ block.settings.label }}"
                loading="lazy"
                width="800"
                height="1000"
              >
            {%- else -%}
              {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          {%- if block.settings.label != blank -%}
            <span class="orf-card-label">{{ block.settings.label }}</span>
          {%- endif -%}
        </a>
      {%- endif -%}
    {%- endfor -%}
  </div>

</div>
</div>

{% schema %}
{
  "name": "Our Favourites Hero",
  "tag": "section",
  "class": "our-favourites-hero",
  "settings": [
    {
      "type": "header",
      "content": "Hero Background"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"

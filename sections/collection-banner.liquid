{% comment %}
  Collection Banner Section
  Renders collection banner images from custom metafields:
  - custom.collection_banner_desktop (Image)
  - custom.collection_banner_mobile (Image)
{% endcomment %}

{% liquid
  assign desktop_banner = collection.metafields.custom.collection_banner_desktop.value | default: collection.metafields.custom.collection_banner_desktop | default: collection.image | default: section.settings.fallback_image_desktop
  assign mobile_banner = collection.metafields.custom.collection_banner_mobile.value | default: collection.metafields.custom.collection_banner_mobile | default: desktop_banner | default: section.settings.fallback_image_mobile
%}

<style>
  #collection-banner-{{ section.id }} {
    width: 100%;
    position: relative;
    overflow: hidden;
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
  }

  .collection-banner__wrapper {
    width: 100%;
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .collection-banner__picture {
    width: 100%;
    display: block;
  }

  .collection-banner__img {
    width: 100%;
    height: auto;
    max-height: {{ section.settings.max_height_desktop }}px;
    object-fit: fill;
    display: block;
  }

  @media screen and (max-width: 749px) {
    .collection-banner__img {
      max-height: {{ section.settings.max_height_mobile }}px;
    }
  }
</style>

{% if desktop_banner != blank or mobile_banner != blank or request.design_mode %}
  <div class="collection-banner-section" id="collection-banner-{{ section.id }}">
    <div class="collection-banner__wrapper">
      {% if desktop_banner != blank %}
        <picture class="collection-banner__picture">
          {% if mobile_banner != blank %}
            <source media="(max-width: 749px)" srcset="{{ mobile_banner | image_url: width: 1000 }}">
          {% endif %}
          <img
            src="{{ desktop_banner | image_url: width: 2200 }}"
            alt="{{ collection.title | escape }}"
            loading="eager"
            width="2200"
            height="{{ 2200 | divided_by: desktop_banner.aspect_ratio | default: 800 | round }}"
            class="collection-banner__img"
          >
        </picture>
      {% elsif request.design_mode %}
        <div class="collection-banner__placeholder" style="width: 100%; height: 350px; background: #f4f4f4; display: flex; align-items: center; justify-content: center; color: #666;">
          <p>Collection Banner (Upload custom.collection_banner_desktop & custom.collection_banner_mobile metafields)</p>
        </div>
      {% endif %}
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "Collection Banner",
  "tag": "section",
  "class": "collection-banner-section-wrapper",
  "settings": [
    {
      "type": "paragraph",
      "content": "Displays desktop image from metafield custom.collection_banner_desktop and mobile image from custom.collection_banner_mobile."
    },
    {
      "type": "image_picker",
      "id": "fallback_image_desktop",
      "label": "Fallback Desktop Banner"
    },
    {
      "type": "image_picker",
      "id": "fallback_image_mobile",
      "label": "Fallback Mobile Banner"
    },
    {
      "type": "range",
      "id": "max_height_desktop",
      "label": "Max Height Desktop (px)",
      "min": 200,
      "max": 1000,
      "step": 20,
      "default": 600
    },
    {
      "type": "range",
      "id": "max_height_mobile",
      "label": "Max Height Mobile (px)",
      "min": 150,
      "max": 800,
      "step": 10,
      "default": 400
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin Top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin Bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Collection Banner"
    }
  ]
}
{% endschema %}

{% liquid
  if section.settings.show_search
    render 'predictive-search-styles'
    render 'slideshow-styles'
  endif

  assign show_language = section.settings.show_language
  if localization.available_languages.size <= 1
    assign show_language = false
  endif

  assign show_country = section.settings.show_country
  if localization.available_countries.size <= 1
    assign show_country = false
  endif
%}

{% capture localization_markup %}
  {% liquid
    assign localization_font = '--menu-localization-font: var(--font-[localization_font]--family); ' | replace: '[localization_font]', section.settings.localization_font
    assign localization_font_size = '--menu-localization-font-size: [localization_font_size]; ' | replace: '[localization_font_size]', section.settings.localization_font_size
    assign color_shadow = '--color-shadow: rgb(var(--color-foreground-rgb) / var(--opacity-10-25));'
    assign form_style = localization_font | append: localization_font_size | append: color_shadow
  %}
  {% if show_language and show_country == false %}
    <div class="dropdown-localization mobile:hidden">
      {% render 'localization-form',
        show_country: show_country,
        show_language: show_language,
        localization_style: 'dropdown',
        form_style: form_style,
        form_id: section.id
      %}
    </div>
  {% elsif show_country %}
    <dropdown-localization-component
      class="dropdown-localization mobile:hidden"
    >
      <button
        type="button"
        class="button dropdown-localization__button localization-selector header-actions__action"
        aria-expanded="false"
        aria-controls="dropdown-localization-results"
        ref="button"
        on:click="/toggleSelector"
        style="{{ localization_font }} {{ localization_font_size }}"
      >
        {% if show_country %}
          {% if section.settings.country_selector_style == true %}
            {% liquid
              assign background_brightness = section.settings.color_scheme_top.settings.background | color_brightness
              if background_brightness < 64
                assign shadow_size = 4
              else
                assign shadow_size = 2
              endif
            %}
            <span
              class="icon-flag"
              style="
                background-image: url({{- localization.country | image_url: width: 32 }});
                --size-shadow: {{ shadow_size }}px;
                --color-shadow: rgb(var(--color-foreground-rgb) / var(--opacity-30-60));
              "
            ></span>
          {% endif %}
          <span
            class="currency-code"
            data-testid="localization-currency-code"
          >
            {{- localization.country.currency.iso_code -}}
          </span>
        {% endif %}
        <span
          class="visually-hidden"
          data-testid="localization-visually-hidden"
        >
          {{- 'accessibility.localization_region_and_language' | t -}}
        </span>

        {%- if show_country and show_language -%}
          <span>/</span>
        {%- endif -%}

        {%- if show_language -%}
          <span>
            {{ localization.language.iso_code | upcase }}
          </span>
        {%- endif -%}
        <span class="svg-wrapper icon-caret">
          {{- 'icon-caret.svg' | inline_asset_content -}}
        </span>
      </button>

      <div
        class="localization-wrapper {{ section.settings.localization_position }}-bound color-{{ settings.popover_color_scheme }}"
        hidden
        ref="panel"
      >
        {% render 'localization-form',
          show_country: show_country,
          show_language: show_language,
          localization_style: 'dropdown',
          form_style: form_style,
          form_id: section.id
        %}
      </div>
    </dropdown-localization-component>
  {% endif %}
{% endcapture %}

{%- capture empty_cart_drawer_content -%}
  <div class="cart-drawer__header">
    <button
      ref="closeButton"
      on:click="cart-drawer-component/close"
      class="button close-button cart-drawer__close-button button-unstyled"
      aria-label="{{ 'actions.close_dialog' | t }}"
    >
      <span class="svg-wrapper">
        {{- 'icon-close.svg' | inline_asset_content -}}
      </span>
    </button>
  </div>
  <div
    class="cart-drawer__content"
    aria-label="{{ 'accessibility.cart' | t }}"
  >
    <h2
      class="cart-drawer__heading h4 cart-drawer__heading--empty"
      id="cart-drawer-heading-empty"
    >
      {{ 'content.your_cart_is_empty' | t }}
    </h2>
    <div class="cart-drawer__items">
      {% render 'cart-products', force_empty: true %}
    </div>
  </div>
{%- endcapture -%}

<header-component
  id="header-component"
  class="header"
  {% if section.settings.enable_sticky_header == 'always' %}
    sticky="always"
  {% elsif section.settings.enable_sticky_header == 'scroll-up' %}
    sticky="scroll-up"
  {% endif %}
>
  <!-- Dummy refs to satisfy requiredRefs in header.js -->
  <div ref="headerDrawerContainer" class="visually-hidden"></div>
  <div ref="headerMenu" class="visually-hidden"></div>
  <div ref="headerRowTop" class="visually-hidden"></div>

  <!-- ROW 1 — Announcement Bar -->
  {%- if section.settings.announcement_text != blank -%}
    <div class="header__announcement-bar">
      <div class="header__announcement-container">
        {{ section.settings.announcement_text }}
      </div>
    </div>
  {%- endif -%}

  <!-- ROW 2 — Main Header Row -->
  <div class="header__main-row">
    <div class="header__main-container">
      
      <!-- Left: Search icon + optional location/currency selector -->
      <div class="header__main-left">
        <!-- Mobile hamburger menu trigger -->
        <div class="header__mobile-menu-trigger desktop:hidden">
          <header-drawer class="header-drawer">
            <details id="Details-menu-drawer-container" class="menu-drawer-container" ref="details" scroll-lock>
              <summary class="header__icon header__icon--menu" aria-label="Menu" on:click="/toggle">
                <span class="svg-wrapper">
                  {{- 'icon-menu.svg' | inline_asset_content -}}
                </span>
              </summary>
              <div ref="menuDrawer" class="menu-drawer color-{{ section.settings.color_scheme_bottom | default: 'scheme-5' }}">
                <button class="button close-button menu-drawer__close-button" type="button" aria-label="Close" on:click="/close">
                  <span class="svg-wrapper">
                    {{- 'icon-close.svg' | inline_asset_content -}}
                  </span>
                </button>
                <nav class="menu-drawer__navigation" aria-label="Navigation">
                  <ul class="menu-drawer__menu" role="list">
                    {%- for link in linklists[section.settings.menu].links -%}
                      <li class="menu-drawer__item">
                        <a href="{{ link.url }}" class="menu-drawer__link{% if section.settings.highlight_item_index > 0 and forloop.index == section.settings.highlight_item_index %} menu-drawer__link--highlighted{% endif %}">
                          {{ link.title }}
                        </a>
                      </li>
                    {%- endfor -%}
                  </ul>
                </nav>
              </div>
            </details>
          </header-drawer>
        </div>

        {%- if section.settings.show_search -%}
          <search-button class="search-action">
            <button
              on:click="#search-modal/showDialog"
              class="button-unstyled header-actions__action"
              aria-label="{{ 'content.search_input_label' | t }}"
              aria-haspopup="dialog"
            >
              <span class="svg-wrapper">
                {{ 'icon-search.svg' | inline_asset_content }}
              </span>
            </button>
          </search-button>
        {%- endif -%}

        {%- if section.settings.show_country or section.settings.show_language -%}
          <div class="header__localization-wrapper mobile:hidden">
            {{ localization_markup }}
          </div>
        {%- endif -%}
      </div>

      <!-- Center: Logo -->
      <div class="header__main-center">
        <a href="{{ routes.root_url }}" class="header-logo-link">
          {%- if settings.logo != blank -%}
            {%- assign logo_alt = settings.logo.alt | default: shop.name -%}
            <img
              src="{{ settings.logo | image_url: width: 300 }}"
              alt="{{ logo_alt | escape }}"
              class="header-logo-img"
              loading="eager"
            >
          {%- else -%}
            <span class="header-logo-text">{{ shop.name }}</span>
          {%- endif -%}
        </a>
      </div>

      <!-- Right: Wishlist, Account, Cart -->
      <div class="header__main-right">
        <header-actions class="header-actions-wrapper">
          <span ref="liveRegion" class="visually-hidden" role="status"></span>

          <!-- Wishlist heart icon -->
          <a href="/pages/wishlist" class="header-actions__action wishlist-button button-unstyled" aria-label="Wishlist">
            <span class="svg-wrapper">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="icon icon-wishlist">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
              </svg>
            </span>
          </a>

          <!-- Account -->
          {%- if shop.customer_accounts_enabled -%}
            <div class="account-button header-actions__action color-{{ settings.popover_color_scheme }}">
              <shopify-account menu="{{ section.settings.customer_account_menu }}">
                {%- if customer -%}
                  <div class="account-button__fallback"></div>
                {%- else -%}
                  <span slot="signed-out-avatar" class="svg-wrapper" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 15 17" fill="none" class="account-button__icon">
                      <path stroke="currentColor" stroke-linejoin="round" stroke-width="1.5" d="M10.375 3.813a3.063 3.063 0 1 1-6.125 0 3.063 3.063 0 0 1 6.125 0ZM7.313 9.5c-3.667 0-6.24 2.691-6.563 6.125h13.125C13.552 12.191 10.979 9.5 7.312 9.5Z" />
                    </svg>
                  </span>
                {%- endif -%}
              </shopify-account>
            </div>
          {%- endif -%}

          <!-- Cart Drawer integration -->
          {%- if settings.cart_type == 'drawer' and template.name != 'cart' -%}
            <cart-drawer-component class="cart-drawer-trigger-wrapper">
              <template id="empty-cart-template">
                {{ empty_cart_drawer_content }}
              </template>
              <button
                class="header-actions__action button-unstyled"
                on:click="/open"
                aria-haspopup="dialog"
                aria-label="{{ 'accessibility.cart' | t }}"
                data-testid="cart-drawer-trigger"
              >
                <span class="header-cart-icon-wrapper">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="icon icon-cart">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007ZM8.625 10.5a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm7.5 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
                  </svg>
                  {% render 'cart-bubble', limit: 100 %}
                </span>
              </button>
              <dialog
                ref="dialog"
                class="cart-drawer__dialog dialog-modal dialog-drawer color-{{ settings.drawer_color_scheme }}{% if cart.empty? %} cart-drawer--empty{%endif%}"
                data-testid="cart-drawer-dialog"
                aria-labelledby="{% if cart.empty? %}cart-drawer-heading-empty{% else %}cart-drawer-heading{% endif %}"
                scroll-lock
                cart-summary-sticky="true"
              >
                <span ref="liveRegion" class="visually-hidden" role="status"></span>
                <div class="cart-drawer__inner">
                  {% capture cart_items_children %}
                    {%- if cart.empty? -%}
                      {{ empty_cart_drawer_content }}
                    {%- else -%}
                      <div class="cart-drawer__header" id="cart-drawer-header">
                        <h2 class="cart-drawer__heading h4" id="cart-drawer-heading">
                          {{ 'content.cart_title' | t }}
                          {% render 'cart-bubble' %}
                        </h2>
                        <button
                          ref="closeButton"
                          on:click="cart-drawer-component/close"
                          class="button close-button cart-drawer__close-button button-unstyled"
                          aria-label="{{ 'actions.close_dialog' | t }}"
                        >
                          <span class="svg-wrapper">
                            {{- 'icon-close.svg' | inline_asset_content -}}
                          </span>
                        </button>
                      </div>
                      <scroll-hint class="cart-drawer__content" aria-label="{{ 'accessibility.cart' | t }}">
                        <scroll-hint class="cart-drawer__items">
                          {% render 'cart-products' %}
                        </scroll-hint>
                        <div class="cart-drawer__summary">
                          {% render 'cart-summary', section_id: section.id %}
                        </div>
                      </scroll-hint>
                    {%- endif -%}
                  {% endcapture %}
                  {% render 'cart-items-component', children: cart_items_children, is_drawer: true, section_id: section.id %}
                </div>
              </dialog>
            </cart-drawer-component>
          {%- else -%}
            <a
              href="{{ routes.cart_url }}"
              class="header-actions__action"
              aria-label="{{ 'accessibility.cart' | t }}"
            >
              <span class="header-cart-icon-wrapper">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="icon icon-cart">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007ZM8.625 10.5a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm7.5 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
                </svg>
                {% render 'cart-bubble', limit: 100 %}
              </span>
            </a>
          {%- endif -%}
        </header-actions>
      </div>

    </div>
  </div>

  <!-- ROW 3 — Navigation Menu Row -->
  {%- if section.settings.menu != blank -%}
    <div class="header__nav-row mobile:hidden">
      <div class="header__nav-container">
        <nav class="header__nav-navigation" aria-label="Navigation">
          <ul class="header-nav-menu" role="list">
            {%-for link in linklists[section.settings.menu].links -%}
              <li class="header-nav-item{% if link.links != blank %} has-dropdown{% endif %}">
                {%- assign is_highlighted = false -%}
                {%- if section.settings.highlight_item_index > 0 and forloop.index == section.settings.highlight_item_index -%}
                  {%- assign is_highlighted = true -%}
                {%- endif -%}
                <a
                  href="{{ link.url }}"
                  class="header-nav-link{% if is_highlighted %} header-nav-link--highlighted{% endif %}"
                  {% if is_highlighted %}
                    style="--highlight-color: {{ section.settings.highlight_color | default: 'var(--color-copper-rivet)' }};"
                  {% endif %}
                >
                  {{ link.title }}
                </a>
                
                {%- if link.links != blank -%}
                  <ul class="header-dropdown-menu" role="list">
                    {%- for child_link in link.links -%}
                      <li class="header-dropdown-item">
                        <a href="{{ child_link.url }}" class="header-dropdown-link">
                          {{ child_link.title }}
                        </a>
                        {%- if child_link.links != blank -%}
                          <ul class="header-grandchild-menu" role="list">
                            {%- for grandchild_link in child_link.links -%}
                              <li class="header-grandchild-item">
                                <a href="{{ grandchild_link.url }}" class="header-grandchild-link">
                                  {{ grandchild_link.title }}
                                </a>
                              </li>
                            {%- endfor -%}
                          </ul>
                        {%- endif -%}
                      </li>
                    {%- endfor -%}
                  </ul>
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        </nav>
      </div>
    </div>
  {%- endif -%}
</header-component>

{%- if section.settings.show_search -%}
  {%- render 'search-modal' -%}
{%- endif -%}

<script
  src="{{ 'header.js' | asset_url }}"
  type="module"
></script>

<script
  type="module"
  src="{{ 'cart-icon.js' | asset_url }}"
  fetchpriority="low"
></script>

<script
  type="module"
  src="{{ 'header-actions.js' | asset_url }}"
  fetchpriority="low"
></script>

<script
  src="{{ 'header-drawer.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{% if settings.cart_type == 'drawer' and template.name != 'cart' %}
  <script
    src="{{ 'cart-drawer.js' | asset_url }}"
    type="module"
    fetchpriority="low"
  ></script>
{% endif %}

{% stylesheet %}
  /* Redesigned 3-Row Header Layout using design tokens */
  :root {
    --spacing-section: var(--global-section-padding-top-mobile, 40px);
  }

  /* Specificity overrides for global theme settings */
  body #header-component.header {
    height: auto !important;
    min-height: 0 !important;
    max-height: none !important;
    display: block !important;
    background-color: var(--color-off-white, #F8F6F2) !important;
    --color-background: var(--color-off-white, #F8F6F2) !important;
    --color-foreground: var(--color-charcoal-grey, #222222) !important;
    --color-primary: var(--color-charcoal-grey, #222222) !important;
    color: var(--color-charcoal-grey, #222222) !important;
  }

  body #header-component.header a,
  body #header-component.header button,
  body #header-component.header summary,
  body #header-component.header span,
  body #header-component.header .header-nav-link,
  body #header-component.header .header-actions__action {
    color: var(--color-charcoal-grey, #222222) !important;
  }

  /* Direct overrides for SVGs and their inner paths/circles to ensure visibility */
  body #header-component.header svg,
  body #header-component.header svg * {
    color: var(--color-charcoal-grey, #222222) !important;
    stroke: var(--color-charcoal-grey, #222222) !important;
  }

  /* ROW 1 — Announcement Bar */
  body #header-component.header .header__announcement-bar {
    background-color: var(--color-vintage-stone, #CFC8BE) !important;
    padding-block: calc(var(--padding-xs) + var(--padding-3xs)) !important; /* exactly 10px */
    text-align: center !important;
    width: 100% !important;
    display: flex !important;
    justify-content: center !important;
    align-items: center !important;
    height: auto !important;
    min-height: 0 !important;
    max-height: none !important;
  }
  
  body #header-component.header .header__announcement-container {
    font-family: var(--font-body--family, 'Inter', sans-serif) !important;
    font-size: var(--font-size--2xs) !important; /* 12px */
    text-transform: uppercase !important;
    letter-spacing: 0.05em !important;
    color: var(--color-charcoal-grey, #222222) !important;
    font-weight: 500 !important;
    line-height: 1.2 !important;
  }

  /* ROW 2 — Main Header Row */
  body #header-component.header .header__main-row {
    background-color: var(--color-off-white, #F8F6F2) !important;
    border-bottom: 1px solid var(--color-border-grey, #E5E5E5) !important;
    width: 100% !important;
    display: flex !important;
    justify-content: center !important;
    height: auto !important;
    min-height: 0 !important;
    max-height: none !important;
  }

  body #header-component.header .header__main-container {
    display: grid !important;
    grid-template-columns: 1fr auto 1fr !important;
    align-items: center !important;
    width: 100% !important;
    max-width: var(--global-max-container-width-desktop, 1440px) !important;
    padding-block: var(--spacing-section) !important;
    padding-inline: var(--global-container-side-padding-mobile, 20px) !important;
    box-sizing: border-box !important;
  }

  @media screen and (min-width: 750px) {
    body #header-component.header .header__main-container,
    body #header-component.header .header__main-row {
      padding-inline: var(--global-section-padding-top-desktop, 60px) !important; /* 60px padding */
     padding-top: 5px !important;
     padding-bottom: 5px !important;
    }
  }

  body #header-component.header .header__main-left {
    display: flex !important;
    align-items: center !important;
    gap: var(--gap-md, 15px) !important;
    justify-content: flex-start !important;
  }

  body #header-component.header .header-actions__action,
  body #header-component.header .wishlist-button,
  body #header-component.header .header-icon-link {
    cursor: pointer !important;
    background: none !important;
    border: none !important;
    padding: var(--padding-2xs, 5px) !important;
    color: var(--color-charcoal-grey, #222222) !important;
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    transition: color var(--hover-transition-duration, 0.25s) var(--hover-transition-timing, ease-out) !important;
  }

  body #header-component.header .header-actions__action svg,
  body #header-component.header .wishlist-button svg,
  body #header-component.header .header-icon-link svg {
    width: 20px !important;
    height: 20px !important;
    stroke: currentColor !important;
    fill: none !important;
    stroke-width: 1.5 !important;
    transition: stroke var(--hover-transition-duration, 0.25s) var(--hover-transition-timing, ease-out) !important;
  }

  /* Hover states */
  body #header-component.header .header-actions__action:hover,
  body #header-component.header .wishlist-button:hover,
  body #header-component.header .header-icon-link:hover,
  body #header-component.header .header-actions__action:hover svg,
  body #header-component.header .wishlist-button:hover svg,
  body #header-component.header .header-icon-link:hover svg {
    color: var(--color-copper-rivet, #B87333) !important;
    stroke: var(--color-copper-rivet, #B87333) !important;
  }

  /* Localization selector overrides */
  body #header-component.header .dropdown-localization__button {
    font-family: var(--font-body--family, 'Inter', sans-serif) !important;
    font-size: var(--font-size--xs) !important; /* 13px */
    color: var(--color-charcoal-grey, #222222) !important;
    font-weight: 500 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.05em !important;
  }

  body #header-component.header .dropdown-localization__button:hover {
    color: var(--color-copper-rivet, #B87333) !important;
  }

  body #header-component.header .header__main-center {
    display: flex !important;
    justify-content: center !important;
    align-items: center !important;
  }

  body #header-component.header .header-logo-link {
    text-decoration: none !important;
    display: inline-block !important;
  }

  body #header-component.header .header-logo-img {
    max-height: 50px !important;
    width: auto !important;
    display: block !important;
  }

  body #header-component.header .header-logo-text {
    font-family: var(--font-body--family, 'Inter', sans-serif) !important;
    font-size: var(--font-size--lg, 18px) !important;
    font-weight: 700 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.1em !important;
    color: var(--color-charcoal-grey, #222222) !important;
  }

  body #header-component.header .header__main-right {
    display: flex !important;
    align-items: center !important;
    justify-content: flex-end !important;
    gap: var(--gap-md, 15px) !important;
  }

  body #header-component.header .header-actions-wrapper {
    display: flex !important;
    align-items: center !important;
    gap: var(--gap-md, 15px) !important;
  }

  body #header-component.header .header-cart-icon-wrapper {
    position: relative !important;
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
  }

  /* ROW 3 — Navigation Menu Row */
  body #header-component.header .header__nav-row {
    background-color: var(--color-off-white, #F8F6F2) !important;
    border-bottom: 1px solid var(--color-border-grey, #E5E5E5) !important;
    width: 100% !important;
    display: flex !important;
    justify-content: center !important;
    height: auto !important;
    min-height: 0 !important;
    max-height: none !important;
  }

  body #header-component.header .header__nav-container {
    width: 100% !important;
    max-width: var(--global-max-container-width-desktop, 1440px) !important;
    display: flex ;
    justify-content: center !important;
    align-items: center !important;
    padding-block: var(--padding-md) !important;
  }

  body #header-component.header .header-nav-menu {
    list-style: none !important;
    padding: 0 !important;
    margin: 0 !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    gap: var(--gap-lg, 24px) !important;
  }

  body #header-component.header .header-nav-item {
    position: relative !important;
  }

  body #header-component.header .header-nav-link {
    font-family: var(--font-body--family, 'Inter', sans-serif) !important;
    font-size: var(--font-size--xs) !important; /* 13px */
    text-transform: uppercase !important;
    letter-spacing: 0.08em !important;
    color: var(--color-charcoal-grey, #222222) !important;
    font-weight: 500 !important;
    text-decoration: none !important;
    position: relative !important;
    padding-block: var(--padding-2xs) !important;
    display: block !important;
    transition: color var(--hover-transition-duration, 0.25s) var(--hover-transition-timing, ease-out) !important;
  }

  body #header-component.header .header-nav-link::after {
    content: '' !important;
    position: absolute !important;
    left: 0 !important;
    right: 0 !important;
    bottom: -4px !important; /* underline 1px offset 4px */
    height: 1px !important;
    background-color: currentColor !important;
    transform: scaleX(0) !important;
    transition: transform var(--hover-transition-duration, 0.25s) var(--hover-transition-timing, ease-out) !important;
  }

  body #header-component.header .header-nav-link:hover {
    color: var(--color-copper-rivet, #B87333) !important;
  }

  body #header-component.header .header-nav-link:hover::after {
    transform: scaleX(1) !important;
  }

  /* Highlight/Sale item overridden style */
  body #header-component.header .header-nav-link--highlighted {
    color: var(--highlight-color, var(--color-copper-rivet, #B87333)) !important;
  }

  /* Simple hover dropdown menu for children links */
  body #header-component.header .header-dropdown-menu {
    position: absolute !important;
    top: 100% !important;
    left: 50% !important;
    transform: translateX(-50%) !important;
    background-color: var(--color-off-white, #F8F6F2) !important;
    border: 1px solid var(--color-border-grey, #E5E5E5) !important;
    box-shadow: 0 var(--hover-lift-amount) var(--margin-xl) rgba(0, 0, 0, 0.08) !important;
    list-style: none !important;
    padding: var(--padding-xs) !important;
    margin: 0 !important;
    min-width: 200px !important;
    opacity: 0 !important;
    visibility: hidden !important;
    transition: opacity 0.2s ease, visibility 0.2s ease !important;
    z-index: 1000 !important;
  }

  body #header-component.header .header-nav-item:hover .header-dropdown-menu {
    opacity: 1 !important;
    visibility: visible !important;
  }

  body #header-component.header .header-dropdown-item {
    position: relative !important;
  }

  body #header-component.header .header-dropdown-link {
    font-family: var(--font-body--family, 'Inter', sans-serif) !important;
    font-size: var(--font-size--2xs, 12px) !important;
    text-transform: uppercase !important;
    letter-spacing: 0.05em !important;
    color: var(--color-charcoal-grey, #222222) !important;
    text-decoration: none !important;
    display: block !important;
    padding: var(--padding-2xs) var(--padding-xs) !important;
    transition: color 0.2s ease !important;
  }

  body #header-component.header .header-dropdown-link:hover {
    color: var(--color-copper-rivet, #B87333) !important;
    background-color: rgba(0, 0, 0, 0.02) !important;
  }

  /* Hover states for SVGs inside hover wrappers */
  body #header-component.header a:hover svg,
  body #header-component.header a:hover svg *,
  body #header-component.header button:hover svg,
  body #header-component.header button:hover svg *,
  body #header-component.header summary:hover svg,
  body #header-component.header summary:hover svg * {
    color: var(--color-copper-rivet, #B87333) !important;
  }

  /* Responsive and Mobile Overrides */
  @media screen and (max-width: 749px) {
    body #header-component.header .header__main-container {
      grid-template-columns: auto 1fr auto !important;
      padding-block: var(--padding-sm) !important;
    }

    body #header-component.header .header__main-left {
      gap: var(--gap-xs, 8px) !important;
    }

    body #header-component.header .header__main-right {
      gap: var(--gap-xs, 8px) !important;
    }

    body #header-component.header .header-actions-wrapper {
      gap: var(--gap-xs, 8px) !important;
    }
  }

  /* Drawer mobile menu styling */
  body #header-component.header .menu-drawer {
    position: fixed !important;
    top: 0 !important;
    left: 0 !important;
    bottom: 0 !important;
    width: 300px !important;
    background-color: var(--color-off-white, #F8F6F2) !important;
    box-shadow: var(--hover-lift-amount) 0 var(--margin-xl) rgba(0, 0, 0, 0.08) !important;
    padding: var(--padding-md) !important;
    z-index: 2000 !important;
  }

  body #header-component.header .menu-drawer__navigation {
    margin-top: var(--padding-xl) !important;
  }

  body #header-component.header .menu-drawer__menu {
    list-style: none !important;
    padding: 0 !important;
    margin: 0 !important;
  }

  body #header-component.header .menu-drawer__item {
    margin-bottom: var(--padding-sm) !important;
  }

  body #header-component.header .menu-drawer__link {
    font-family: var(--font-body--family, 'Inter', sans-serif) !important;
    font-size: var(--font-size--sm, 14px) !important;
    text-transform: uppercase !important;
    letter-spacing: 0.08em !important;
    color: var(--color-charcoal-grey, #222222) !important;
    font-weight: 500 !important;
    text-decoration: none !important;
    display: block !important;
  }

  body #header-component.header .menu-drawer__link--highlighted {
    color: var(--color-copper-rivet, #B87333) !important;
  }
{% endstylesheet %}

{% unless request.design_mode %}
  <script type="module">
    import { hydrate } from '@theme/section-hydration';
    const url = new URL(window.location.href);
    url.searchParams.delete('page');
    hydrate('{{ section.id }}', url);
  </script>
{% endunless %}


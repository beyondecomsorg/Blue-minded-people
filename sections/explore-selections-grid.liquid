{% comment %}
  Explore Selections — 4-column category grid
{% endcomment %}

<style>

  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
  }

  .ebs-wrap {
    max-width: var(--global-max-container-width-desktop);
    margin: 0 auto;
    padding: 0 var(--global-container-side-padding-desktop);
  }

  @media screen and (max-width: 749px) {
    .ebs-wrap {
      padding: 0 var(--global-container-side-padding-mobile);
    }
  }

  /* Heading */
  .ebs-heading {
    font-family: var(--font-heading--family);
    font-size: var(--font-h2--size);
    font-weight: var(--font-h2--weight);
    color: var(--color-deep-navy);
    text-align: center;
    letter-spacing: var(--font-h2--letter-spacing);
    margin: 0 0 28px;
    line-height: var(--font-h2--line-height);
    text-transform: uppercase;
  }

  /* Grid */
  .ebs-grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    gap: {{ section.settings.row_gap }}px {{ section.settings.col_gap }}px;
  }

  /* Card */
  .ebs-card {
    display: block;
    text-decoration: none;
  }

  .ebs-img-wrap {
    width: 100%;
    aspect-ratio: {{ section.settings.card_ratio }};
    overflow: hidden;
    background: var(--color-off-white);
    border: 1px solid var(--color-border-grey);
    display: block;
  }

  .ebs-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
    transition: transform 0.45s ease;
  }

  .ebs-card:hover .ebs-img-wrap img {
    transform: scale(1.04);
  }

  .ebs-card-label {
    font-family: var(--font-body--family);
    font-size: var(--font-paragraph--size);
    font-weight: 600;
    color: var(--color-deep-navy);
    text-align: center;
    margin: 12px 0 0;
    text-transform: uppercase;
    line-height: 1.4;
  }

  /* Tablet */
  @media (max-width: 1024px) {
    .ebs-grid {
      grid-template-columns: repeat({{ section.settings.columns_tablet }}, 1fr);
    }
  }

  /* Mobile */
  @media (max-width: 640px) {
    .ebs-grid {
      grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr);
      gap: {{ section.settings.row_gap | times: 0.75 | round }}px {{ section.settings.col_gap | times: 0.75 | round }}px;
    }
  }
</style>

<div class="ebs-wrap section-wrapper" style="--section-padding-top: {{ section.settings.padding_top }}px; --section-padding-bottom: {{ section.settings.padding_bottom }}px; --section-padding-top-mobile: {{ section.settings.padding_top_mobile }}px; --section-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;">
  {%- if section.settings.heading != blank -%}
    <h2 class="ebs-heading">{{ section.settings.heading }}</h2>
  {%- endif -%}

  <div class="ebs-grid">
    {%- for block in section.blocks -%}
      {%- if block.type == 'category_card' -%}
        <a href="{{ block.settings.card_url }}" class="ebs-card" {{ block.shopify_attributes }}>
          <div class="ebs-img-wrap">
            {%- if block.settings.card_image != blank -%}
              <img
                src="{{ block.settings.card_image | img_url: '700x' }}"
                alt="{{ block.settings.label }}"
                loading="lazy"
                width="700"
                height="875"
              >
            {%- else -%}
              {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          {%- if block.settings.label != blank -%}
            <p class="ebs-card-label">{{ block.settings.label }}</p>
          {%- endif -%}
        </a>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Explore Selections Grid",
  "tag": "section",
  "class": "explore-selections-grid",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Explore Blue Minded People Selections"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Size",
      "min": 16,
      "max": 52,
      "step": 1,
      "unit": "px",
      "default": 30
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading Weight",
      "default": "400",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Regular" },
        { "value": "600", "label": "Semi Bold" },
        { "value": "700", "label": "Bold" }
      ]
    },
    {
      "type": "select",
      "id": "heading_style",
      "label": "Heading Style",
      "default": "normal",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "italic", "label": "Italic" }
      ]
    },
    {
      "type": "range",
      "id": "heading_tracking",
      "label": "Letter Spacing",
      "min": 0,
      "max": 20,
      "step": 1,
      "default": 2,
      "info": "Value ÷ 100 = em unit"
    },
    {
      "type": "select",
      "id": "heading_align",
      "label": "Heading Alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "heading_gap",
      "label": "Space Below Heading",
      "min": 8,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "header",
      "content": "Grid Layout"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns (Desktop)",
      "default": "4",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" }
      ]
    },
    {
      "type": "select",
      "id": "columns_tablet",
      "label": "Columns (Tablet)",
      "default": "2",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" }
      ]
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns (Mobile)",
      "default": "2",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ]
    },
    {
      "type": "range",
      "id": "col_gap",
      "label": "Column Gap",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "row_gap",
      "label": "Row Gap",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "select",
      "id": "card_ratio",
      "label": "Card Image Ratio",
      "default": "4/5",
      "options": [
        { "value": "1/1", "label": "Square 1:1" },
        { "value": "3/4", "label": "Portrait 3:4" },
        { "value": "4/5", "label": "Standard 4:5" },
        { "value": "2/3", "label": "Tall 2:3" }
      ]
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card Background",
      "default": "#f2f2f0"
    },
    {
      "type": "header",
      "content": "Card Label"
    },
    {
      "type": "range",
      "id": "label_size",
      "label": "Label Size",
      "min": 10,
      "max": 22,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "select",
      "id": "label_weight",
      "label": "Label Weight",
      "default": "400",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Regular" },
        { "value": "600", "label": "Semi Bold" },
        { "value": "700", "label": "Bold" }
      ]
    },
    {
      "type": "select",
      "id": "label_style",
      "label": "Label Style",
      "default": "normal",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "italic", "label": "Italic" }
      ]
    },
    {
      "type": "select",
      "id": "label_align",
      "label": "Label Alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label Color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "label_gap",
      "label": "Space Above Label",
      "min": 4,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "select",
      "id": "font_family",
      "label": "Font Family",
      "default": "inherit",
      "options": [
        { "value": "inherit", "label": "Theme Default" },
        { "value": "Georgia, serif", "label": "Georgia" },
        { "value": "'Times New Roman', serif", "label": "Times New Roman" },
        { "value": "Helvetica, Arial, sans-serif", "label": "Helvetica" }
      ]
    },
    {
      "type": "header",
      "content": "Background & Padding"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "container_width",
      "label": "Max Container Width",
      "min": 800,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "default": 1280
    },
    {
      "type": "range",
      "id": "side_padding",
      "label": "Side Padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Section top padding — desktop (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Section bottom padding — desktop (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Section top padding — mobile (px)",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Section bottom padding — mobile (px)",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "category_card",
      "name": "Category Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "card_image",
          "label": "Card Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Category Name"
        },
        {
          "type": "url",
          "id": "card_url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Explore Selections Grid",
      "blocks": [
        { "type": "category_card", "settings": { "label": "Apparel" } },
        { "type": "category_card", "settings": { "label": "Men's Accessories" } },
        { "type": "category_card", "settings": { "label": "Women's Accessories" } },
        { "type": "category_card", "settings": { "label": "Women's Shoes" } },
        { "type": "category_card", "settings": { "label": "Men's Bags" } },
        { "type": "category_card", "settings": { "label": "Women's Accessories" } },
        { "type": "category_card", "settings": { "label": "Men's Shoes" } },
        { "type": "category_card", "settings": { "label": "Caps" } }
      ]
    }
  ]
}
{% endschema %}

{% comment %}
  Shop by Category — Fabric Cards Section
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} {
    background-color: var(--color-off-white);
    padding-top: var(--global-section-padding-top);
    padding-bottom: var(--global-section-padding-bottom);
  }

  .sbc-container {
    max-width: var(--global-max-container-width-desktop);
    margin: 0 auto;
    padding: 0 20px;
  }

  .sbc-heading {
    text-align: center;
    font-family: var(--font-heading--family);
    font-size: var(--font-h2--size);
    line-height: var(--font-h2--line-height);
    letter-spacing: var(--font-h2--letter-spacing);
    font-weight: var(--font-h2--weight);
    color: var(--color-deep-navy);
    margin: 0 0 28px;
    text-transform: uppercase;
  }

  .sbc-grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    gap: {{ section.settings.card_gap }}px;
  }

  .sbc-card {
    border: 1.5px solid var(--color-border-grey);
    background: var(--color-off-white);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    text-decoration: none;
  }

  .sbc-card-img {
    width: 100%;
    aspect-ratio: {{ section.settings.image_ratio }};
    overflow: hidden;
    display: block;
  }

  .sbc-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
    transition: transform 0.4s ease;
  }

  .sbc-card:hover .sbc-card-img img {
    transform: scale(1.04);
  }

  .sbc-card-body {
    padding: 16px 14px 18px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    flex: 1;
  }

  .sbc-card-title {
    font-family: var(--font-body--family);
    font-size: var(--font-paragraph--size);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-deep-navy);
    text-align: center;
    line-height: 1.3;
    margin: 0;
  }

  .sbc-card-btn {
    display: inline-block;
    font-family: var(--font-body--family);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--color-deep-navy);
    background: var(--color-off-white);
    border: 1.5px solid var(--color-deep-navy);
    padding: 9px 28px;
    text-decoration: none;
    text-align: center;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    white-space: nowrap;
  }

  .sbc-card:hover .sbc-card-btn {
    background: var(--color-copper-rivet);
    color: var(--color-off-white);
    border-color: var(--color-copper-rivet);
  }

  @media (max-width: 1024px) {
    .sbc-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 640px) {
    .sbc-grid {
      grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr);
      gap: 12px;
    }
  }
</style>

<div class="sbc-container">
  {% if section.settings.heading != blank %}
    <h2 class="sbc-heading">{{ section.settings.heading }}</h2>
  {% endif %}

  <div class="sbc-grid">
    {% for block in section.blocks %}
      {% if block.type == 'category_card' %}
        <a
          href="{{ block.settings.card_url }}"
          class="sbc-card"
          {{ block.shopify_attributes }}
        >
          <div class="sbc-card-img">
            {% if block.settings.card_image != blank %}
              <img
                src="{{ block.settings.card_image | img_url: '600x' }}"
                alt="{{ block.settings.card_title }}"
                loading="lazy"
                width="600"
                height="750"
              >
            {% else %}
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {% endif %}
          </div>
          <div class="sbc-card-body">
            <p class="sbc-card-title">{{ block.settings.card_title }}</p>
            <span class="sbc-card-btn">{{ block.settings.btn_label | default: 'Shop Now' }}</span>
          </div>
        </a>
      {% endif %}
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Shop By Category",
  "tag": "section",
  "class": "shop-by-category",
  "settings": [
    {
      "type": "header",
      "content": "Section Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "SHOP TROUSERS FABRIC BY CATEGORY"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Font Size",
      "min": 16,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "heading_gap",
      "label": "Space Below Heading",
      "min": 8,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#111111"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "container_width",
      "label": "Max Container Width",
      "min": 800,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "default": 1400
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns (Desktop)",
      "default": "6",
      "options": [
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" },
        { "value": "6", "label": "6" }
      ]
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns (Mobile)",
      "default": "2",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ]
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Gap Between Cards",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image Aspect Ratio",
      "default": "3/4",
      "options": [
        { "value": "1/1", "label": "Square (1:1)" },
        { "value": "3/4", "label": "Portrait (3:4)" },
        { "value": "2/3", "label": "Tall (2:3)" },
        { "value": "4/5", "label": "Standard (4:5)" }
      ]
    },
    {
      "type": "header",
      "content": "Card Styles"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Card Border Color",
      "default": "#dddddd"
    },
    {
      "type": "color",
      "id": "card_title_color",
      "label": "Card Title Color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "card_title_size",
      "label": "Card Title Size",
      "min": 10,
      "max": 22,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "color",
      "id": "btn_bg_color",
      "label": "Button Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Button Text Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "btn_border_color",
      "label": "Button Border Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "btn_hover_bg",
      "label": "Button Hover Background",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "btn_hover_text",
      "label": "Button Hover Text",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "select",
      "id": "font_family",
      "label": "Font Family",
      "default": "inherit",
      "options": [
        { "value": "inherit", "label": "Theme Default" },
        { "value": "Helvetica, Arial, sans-serif", "label": "Helvetica" },
        { "value": "'Times New Roman', serif", "label": "Times New Roman" },
        { "value": "Georgia, serif", "label": "Georgia" },
        { "value": "Futura, 'Trebuchet MS', sans-serif", "label": "Futura" }
      ]
    },
    {
      "type": "header",
      "content": "Background & Padding"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "category_card",
      "name": "Category Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "card_image",
          "label": "Card Image"
        },
        {
          "type": "text",
          "id": "card_title",
          "label": "Card Title",
          "default": "FABRIC CATEGORY"
        },
        {
          "type": "text",
          "id": "btn_label",
          "label": "Button Label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "card_url",
          "label": "Card Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop By Category",
      "blocks": [
        { "type": "category_card", "settings": { "card_title": "REGULAR TROUSER FABRIC" } },
        { "type": "category_card", "settings": { "card_title": "POLYWOOL TROUSER FABRIC" } },
        { "type": "category_card", "settings": { "card_title": "LYCRA TROUSER FABRIC" } },
        { "type": "category_card", "settings": { "card_title": "PURE COTTON TROUSER FABRIC" } },
        { "type": "category_card", "settings": { "card_title": "DENIM TROUSER FABRIC" } },
        { "type": "category_card", "settings": { "card_title": "COURDRAY TROUSER FABRIC" } }
      ]
    }
  ]
}
{% endschema %}

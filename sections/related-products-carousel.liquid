{%- liquid
  assign related_products = product.metafields.custom.related_products.value
  assign has_related_products = false
  if related_products != blank and related_products.size > 0
    assign has_related_products = true
  endif
-%}

{%- if has_related_products -%}
  <div
    id="related-products-{{ section.id }}"
    class="related-products-section"
    style="
      --padding-top-desktop: {{ section.settings.padding_top_desktop }}px;
      --padding-bottom-desktop: {{ section.settings.padding_bottom_desktop }}px;
      --padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
      --padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
      --gap-heading-carousel: {{ section.settings.gap_heading_carousel }}px;
      --bg-color: {{ section.settings.bg_color }};
      --gap: {{ section.settings.gap }}px;
      --cards-desktop: {{ section.settings.cards_desktop }};
      --cards-mobile: {{ section.settings.cards_mobile }};
      --card-radius: {{ section.settings.card_border_radius }}px;
      --heading-size-desktop: {{ section.settings.heading_size_desktop }}px;
      --heading-size-mobile: {{ section.settings.heading_size_mobile }}px;
      --title-size-desktop: {{ section.settings.title_size_desktop }}px;
      --title-size-mobile: {{ section.settings.title_size_mobile }}px;
      --title-weight: {{ section.settings.title_font_weight }};
    "
  >
    <div class="page-width">
      <related-products-carousel class="carousel">
        <div class="carousel__header">
          <div class="carousel__title-block">
            {%- if section.settings.heading != blank -%}
              <h2 class="carousel__heading">{{ section.settings.heading }}</h2>
            {%- endif -%}
            {%- if section.settings.show_subheading and section.settings.subheading != blank -%}
              <p class="carousel__subheading">{{ section.settings.subheading }}</p>
            {%- endif -%}
          </div>
          {%- if section.settings.show_nav_arrows -%}
            <div class="carousel__nav" aria-label="Carousel navigation">
              <button class="carousel__btn carousel__btn--prev" aria-label="Previous products" disabled>
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
                </svg>
              </button>
              <button class="carousel__btn carousel__btn--next" aria-label="Next products">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                </svg>
              </button>
            </div>
          {%- endif -%}
        </div>

        <div class="carousel__track-wrap">
          <div class="carousel__track">
            {%- for rel_product in related_products -%}
              <a href="{{ rel_product.url }}" class="carousel__card">
                <div class="carousel__image-container">
                  {%- if rel_product.featured_media != blank -%}
                    {{ rel_product.featured_media | image_url: width: 800 | image_tag: loading: 'lazy', sizes: '(min-width: 750px) 25vw, 80vw', class: 'carousel__image' }}
                  {%- else -%}
                    {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg carousel__image' }}
                  {%- endif -%}
                </div>
                <h3 class="carousel__card-title">{{ rel_product.title }}</h3>
              </a>
            {%- endfor -%}
          </div>
        </div>
      </related-products-carousel>
    </div>
  </div>

  <style>
  .related-products-section {
    width: 100%;
    background-color: var(--bg-color);
    box-sizing: border-box;
    padding-top: var(--padding-top-mobile);
    padding-bottom: var(--padding-bottom-mobile);
  }

  @media screen and (min-width: 750px) {
    .related-products-section {
      padding-top: var(--padding-top-desktop);
      padding-bottom: var(--padding-bottom-desktop);
    }
  }

  related-products-carousel {
    display: block;
    width: 100%;
  }

  .carousel__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: var(--gap-heading-carousel);
  }

  .carousel__title-block {
    display: flex;
    flex-direction: column;
    gap: 6px;
    text-align: left;
  }

  .carousel__heading {
    font-family: var(--font-heading, var(--font-heading--family, "Canela", serif));
    font-weight: 700;
    letter-spacing: normal;
    color: var(--color-foreground-heading, var(--color-foreground, #0B1F33));
    font-size: var(--heading-size-mobile);
    margin: 0;
    line-height: 1.2;
  }

  @media screen and (min-width: 750px) {
    .carousel__heading {
      font-size: var(--heading-size-desktop);
    }
  }

  .carousel__subheading {
    font-family: var(--font-body, var(--font-body--family, "Inter", sans-serif));
    font-size: 14px;
    color: var(--color-medium-grey, #666666);
    margin: 0;
    line-height: 1.4;
  }

  .carousel__nav {
    display: flex;
    gap: 8px;
    align-items: center;
  }

  @media screen and (max-width: 749px) {
    .carousel__nav {
      display: none;
    }
  }

  .carousel__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid var(--color-border, #E5E5E5);
    background-color: var(--color-white, #FFFFFF);
    color: var(--color-foreground, #222222);
    cursor: pointer;
    padding: 0;
    transition: opacity 0.25s ease, background-color 0.25s ease;
  }

  .carousel__btn:hover:not(:disabled) {
    background-color: var(--color-off-white, #FFFFFF);
  }

  .carousel__btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .carousel__track-wrap {
    position: relative;
    width: 100%;
  }

  .carousel__track {
    display: flex;
    gap: var(--gap);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }

  .carousel__track::-webkit-scrollbar {
    display: none;
  }

  .carousel__card {
    display: block;
    text-decoration: none;
    flex: 0 0 calc((100% - (var(--cards-mobile) - 1) * var(--gap)) / var(--cards-mobile));
    scroll-snap-align: start;
    box-sizing: border-box;
  }

  @media screen and (min-width: 600px) {
    .carousel__card {
      flex: 0 0 calc((100% - (3 - 1) * var(--gap)) / 3);
    }
  }

  @media screen and (min-width: 990px) {
    .carousel__card {
      flex: 0 0 calc((100% - (var(--cards-desktop) - 1) * var(--gap)) / var(--cards-desktop));
    }
  }

  .carousel__image-container {
    position: relative;
    width: 100%;
    aspect-ratio: 3/4;
    overflow: hidden;
    background-color: var(--color-vintage-stone, #CFC8BE);
    border-radius: var(--card-radius);
  }

  .carousel__image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.3s ease;
  }

  @media (hover: hover) {
    .carousel__card:hover .carousel__image {
      transform: scale(1.03);
    }
  }

  .carousel__card-title {
    font-family: var(--font-body, var(--font-body--family, "Inter", sans-serif));
    font-size: var(--title-size-mobile);
    font-weight: var(--title-weight);
    color: var(--color-charcoal-grey, #222222);
    margin: 12px 0 0 0;
    line-height: 1.4;
    text-align: left;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @media screen and (min-width: 750px) {
    .carousel__card-title {
      font-size: var(--title-size-desktop);
    }
  }
  </style>

  <script>
    if (!customElements.get('related-products-carousel')) {
      class RelatedProductsCarousel extends HTMLElement {
        connectedCallback() {
          this.track = this.querySelector('.carousel__track');
          this.btnPrev = this.querySelector('.carousel__btn--prev');
          this.btnNext = this.querySelector('.carousel__btn--next');

          if (this.track) {
            if (this.btnPrev && this.btnNext) {
              this.btnPrev.addEventListener('click', () => this.scrollTrack(-1));
              this.btnNext.addEventListener('click', () => this.scrollTrack(1));
              this.track.addEventListener('scroll', () => this.updateButtons());
              setTimeout(() => this.updateButtons(), 100);
            }
          }
        }

        scrollTrack(direction) {
          const card = this.querySelector('.carousel__card');
          if (!card) return;
          const cardWidth = card.offsetWidth;
          const gap = parseFloat(getComputedStyle(this.track).gap) || 0;
          const scrollAmount = (cardWidth + gap) * direction;
          this.track.scrollBy({ left: scrollAmount, behavior: 'smooth' });
        }

        updateButtons() {
          const scrollLeft = this.track.scrollLeft;
          const maxScrollLeft = this.track.scrollWidth - this.track.clientWidth;
          
          this.btnPrev.disabled = scrollLeft <= 2;
          this.btnNext.disabled = scrollLeft >= maxScrollLeft - 2;
        }
      }
      customElements.define('related-products-carousel', RelatedProductsCarousel);
    }
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Related Products Carousel",
  "class": "related-products-carousel-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You May Also Like"
    },
    {
      "type": "checkbox",
      "id": "show_subheading",
      "label": "Show Subheading",
      "default": true
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading Text",
      "default": "Complete the look"
    },
    {
      "type": "range",
      "id": "cards_desktop",
      "label": "Visible cards (Desktop)",
      "min": 3,
      "max": 6,
      "step": 1,
      "default": 5
    },
    {
      "type": "range",
      "id": "cards_mobile",
      "label": "Visible cards (Mobile)",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "default": 1.2
    },
    {
      "type": "checkbox",
      "id": "show_nav_arrows",
      "label": "Show navigation arrows (Desktop)",
      "default": true
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Card border radius",
      "min": 0,
      "max": 16,
      "step": 1,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "label": "Heading Size (Desktop)",
      "min": 24,
      "max": 36,
      "step": 1,
      "default": 28,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading Size (Mobile)",
      "min": 20,
      "max": 26,
      "step": 1,
      "default": 22,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "title_size_desktop",
      "label": "Product Title Size (Desktop)",
      "min": 13,
      "max": 16,
      "step": 1,
      "default": 14,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "label": "Product Title Size (Mobile)",
      "min": 12,
      "max": 14,
      "step": 1,
      "default": 13,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "title_font_weight",
      "label": "Product Title Font Weight",
      "options": [
        {
          "value": "400",
          "label": "Regular"
        },
        {
          "value": "500",
          "label": "Medium"
        }
      ],
      "default": "400"
    },
    {
      "type": "header",
      "content": "Background and Spacing"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#F8F6F2"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between cards",
      "min": 12,
      "max": 32,
      "step": 1,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "gap_heading_carousel",
      "label": "Space between header & carousel",
      "min": 20,
      "max": 48,
      "step": 1,
      "default": 32,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Desktop Padding Top",
      "min": 0,
      "max": 120,
      "step": 5,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Desktop Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 5,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Mobile Padding Top",
      "min": 0,
      "max": 80,
      "step": 2,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Mobile Padding Bottom",
      "min": 0,
      "max": 80,
      "step": 2,
      "default": 40,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Related Products Carousel"
    }
  ]
}
{% endschema %}

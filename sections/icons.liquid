      "id": "label_size",
      "label": "Label font size (px)",
      "min": 9,
      "max": 16,
      "step": 1,
      "default": 11
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "subtext_color",
      "label": "Subtext color",
      "default": "#444444"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Icon label color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "inline_link_color",
      "label": "Inline link color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "btn_bg",
      "label": "Button background",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "btn_text_color",
